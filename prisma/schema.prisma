generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String?   @unique
  password         String?
  discordId        String?   @unique
  createdVia       String    @default("site")
  avatar           String?
  bio              String?
  dateOfBirth      DateTime?
  role             Role      @default(USER)
  createdAt        DateTime  @default(now())
  timezone         String    @default("UTC")
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?

  referralSource   String?   // "how did you find us" answer at signup
  socialLinks      Json?     // [{ platform: "Twitter", url: "https://..." }, ...]
  projectType      String?   // "novel" | "fanfic" | "short_story" | "other"
  timeOnProject    String?   // "less_1month" | "1_6months" | "6_12months" | "over_1year"
  biggestBlock     String? 
  
  blogLastSeen  BlogLastSeen?

  challengeLongestStreak   Int     @default(0)  

  // ── existing relations ──────────────────────────────────────────────────
  challengeParticipations  ChallengeParticipation[]
  challengeCheckIns        ChallengeCheckIn[]

  notificationPreference NotificationPreference?
  sprintReminderOptIn    SprintReminderOptIn?  
  groupSprints        GroupSprint[]
  sprints             Sprint[]
  notification        Notification[]
  blogPostLikes       BlogPostLike[]
  blogComments        BlogComment[]
  blogReplies         BlogReply[]
  soundscapes         Soundscape[]
  writingDrafts       WritingDraft[]
  

  // ── feedback hub relations ──────────────────────────────────────────────
  feedbackPoints              FeedbackPoint?
  feedbackSubmissions         FeedbackSubmission[]
  feedbackResponses           FeedbackResponse[]
  paragraphComments           ParagraphComment[]
  paragraphCommentReplies     ParagraphCommentReply[]
  paragraphCommentUpvotes     ParagraphCommentUpvote[]
  feedbackResponseUpvotes     FeedbackResponseUpvote[]
  critiqueReportsSubmitted    CritiqueReport[]  @relation("ReportSubmitter")
  critiqueReportsResolved     CritiqueReport[]  @relation("ReportResolver")

  blocksMade      UserBlock[]  @relation("BlocksMade")
  blocksReceived  UserBlock[]  @relation("BlocksReceived")

  // ── Direct Message relations ──────────────────────────────────────────────
  directConversationsAsA  DirectConversation[] @relation("ConversationUserA")
  directConversationsAsB  DirectConversation[] @relation("ConversationUserB")
  sentMessages            DirectMessage[]      @relation("MessageSender")

  // ── thread relations ─────────────────────────────────────────────────────
  threads             Thread[]
  threadLikes         ThreadLike[]
  threadComments      ThreadComment[]
  threadCommentLikes  ThreadCommentLike[]
  threadReplies       ThreadReply[]
  threadReplyLikes    ThreadReplyLike[]

  // ── draft plan relations ─────────────────────────────────────────────────
  draftPlan            DraftPlan?
  draftProgressLogs    DraftProgressLog[]

  // ── days challenge relations ─────────────────────────────────────────────
  daysChallenge        DaysChallenge?
  daysChallengeCheckIns DaysChallengeCheckIn[]
}

model UserBlock {
  id        Int      @id @default(autoincrement())
  blockerId Int                          // the user who did the blocking
  blockedId Int                          // the user who was blocked
  createdAt DateTime @default(now())

  blocker   User     @relation("BlocksMade",     fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])       // can't block the same person twice
  @@index([blockerId])
  @@index([blockedId])
}

model ChallengeParticipation {
  id               Int           @id @default(autoincrement())
  userId           Int           @unique   // one active slot per writer at a time (enforced in service)
 
  // Goal the writer set when they joined
  goalValue        Int         @default(0) // e.g. 500 (words), 2 (chapters), 3 (scenes), 30 (minutes)
  goalType         GoalType    @default(WORDS)  // WORDS | CHAPTERS | SCENES | DURATION
 
  // Streak tracking
  currentStreak    Int           @default(0)
  longestStreak    Int           @default(0)   // local copy for leaderboard queries
  missedDaysInRow  Int           @default(0)
  lastCheckInDate  DateTime?
 
  joinedAt         DateTime      @default(now())
  isActive         Boolean       @default(true)
  remindersEnabled Boolean       @default(true)
 
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns  ChallengeCheckIn[]
 
  @@index([userId])
  @@index([isActive])
  @@index([currentStreak])
  @@index([joinedAt])
}

// One row per day a writer logs progress in a challenge.
model ChallengeCheckIn {
  id              Int      @id @default(autoincrement())
  participationId Int
  userId          Int
  checkInDate     DateTime                       // the calendar date (stored as midnight UTC)
  countLogged     Int                            // words or chapters logged for this day
  metDailyGoal    Boolean  @default(false)       // true if countLogged >= participation.dailyGoal
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  participation  ChallengeParticipation  @relation(fields: [participationId], references: [id], onDelete: Cascade)
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Only one check-in entry per participation per day
  @@unique([participationId, checkInDate])
  @@index([participationId])
  @@index([userId])
  @@index([checkInDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// GROUP SPRINT & SPRINT
// ─────────────────────────────────────────────────────────────────────────────

model GroupSprint {
  id                Int        @id @default(autoincrement())
  userId            Int
  duration          Int
  totalWordsWritten Int        @default(0)
  liveKitRoomName   String?
  visibility        Visibility @default(PUBLIC)
  sprintType        SprintType @default(WRITING)
  startedAt         DateTime   @default(now())
  completedAt       DateTime?
  isActive          Boolean    @default(true)

  sprints           Sprint[]
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([startedAt])
  @@index([visibility])
}

model Sprint {
  id            Int          @id @default(autoincrement())
  userId        Int
  groupSprintId Int?
  soundscapeId  Int?
  projectId     Int?
  checkin       String?
  startWords    Int          @default(0)
  wordsWritten  Int          @default(0)
  deletedWords  Int          @default(0)
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  isActive      Boolean      @default(true)

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupSprint   GroupSprint? @relation(fields: [groupSprintId], references: [id], onDelete: SetNull)
  soundscape    Soundscape?  @relation(fields: [soundscapeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([groupSprintId])
  @@index([isActive])
  @@index([soundscapeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SOUNDSCAPE
// ─────────────────────────────────────────────────────────────────────────────

model Soundscape {
  id            Int       @id @default(autoincrement())
  name          String
  creatorName   String?
  fileUrl       String
  contributedBy Int
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  contributor   User      @relation(fields: [contributedBy], references: [id], onDelete: Cascade)
  sprints       Sprint[]

  @@index([contributedBy])
  @@index([isApproved])
}

// ─────────────────────────────────────────────────────────────────────────────
// QUOTES, SUBSCRIPTIONS, NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// SPRINT REMINDER OPT-IN
//
// Tracks which users want to be notified before the weekly Friday sprint.
// One row per user — upserted when they toggle the checkbox in the UI.
// ─────────────────────────────────────────────────────────────────────────────

model SprintReminderOptIn {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique          // one row per user
  optedIn               Boolean  @default(true)   // false = soft-disabled without deleting the row
  reminderMinutesBefore Int      @default(30)      // future-proofing: user-configurable lead time
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([optedIn])   // the cron job filters on this
}

model Subscription {
  id           Int      @id @default(autoincrement())
  userId       Int
  subscription Json
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        Int              @id @default(autoincrement())
  username  String
  userId    Int
  message   String?
  link      String?
  read      Boolean?         @default(false)
  type      NotificationType @default(GENERAL)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([userId, type])
}

// Used to filter what shows up on the main /notifications bell page.
// MESSAGE and COMMUNITY_UPDATE are reserved for completeness (e.g. future
// "all activity" views) but notifyUser() currently skips creating an inbox
// row for those two types entirely — they're represented by the dedicated
// Messages and Community Updates pages + sidebar badges instead.
enum NotificationType {
  GENERAL           // catch-all / legacy rows created before this field existed
  REACTION          // likes on posts, comments, threads, etc.
  COMMENT           // someone commented/replied on the user's content
  CRITIQUE          // feedback hub activity (new response, report resolved, etc.)
  MESSAGE           // new direct message — reserved, not currently written to inbox
  COMMUNITY_UPDATE  // new blog/community post — reserved, not currently written to inbox
  SYSTEM            // account/admin-level notices
}

model NotificationPreference {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferences Json     @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────────────────────────────────────

model BlogPost {
  id        Int            @id @default(autoincrement())
  title     String?
  content   String
  mediaUrl  String?
  link      String?
  category  String?
  tag       String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  likes     BlogPostLike[]
  comments  BlogComment[]

  // ── series support ───────────────────────────────────────────────────────
  // A post can optionally belong to a series (e.g. an event's story
  // submissions). seriesOrder controls its position for "next/previous"
  // navigation. Posts with seriesId = null are standalone, single posts.
  seriesId    Int?
  seriesOrder Int?
  series      BlogSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  isPinned    Boolean  @default(false)

  @@index([createdAt])
  @@index([seriesId])
  @@index([seriesId, seriesOrder])
  @@index([isPinned])
}

// ─────────────────────────────────────────────────────────────────────────────
// BLOG SERIES
//
// Groups related blog posts together (e.g. an ongoing story, or all of the
// submissions for a community event) so they can be browsed as a collection
// and linked with "next/previous" navigation.
// ─────────────────────────────────────────────────────────────────────────────

model BlogSeries {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  description String?
  coverUrl    String?
  category    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  posts       BlogPost[]

  @@index([slug])
}

model BlogPostLike {
  id         Int      @id @default(autoincrement())
  userId     Int
  blogPostId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([userId, blogPostId])
  @@index([blogPostId])
}

model BlogComment {
  id         Int         @id @default(autoincrement())
  blogPostId Int
  authorId   Int?                                                         // <-- nullable
  content    String
  createdAt  DateTime    @default(now())
  post       BlogPost    @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  author     User?       @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull
  replies    BlogReply[]

  @@index([blogPostId])
  @@index([authorId])
}

model BlogReply {
  id        Int         @id @default(autoincrement())
  commentId Int
  authorId  Int?                                                          // <-- nullable
  content   String
  createdAt DateTime    @default(now())
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User?       @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull

  @@index([commentId])
  @@index([authorId])
}

model BlogLastSeen {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  lastSeenAt DateTime @default(now())

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// THREADS  (admin-created forum posts; members like, comment, reply)
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// THREAD CATEGORY
// ─────────────────────────────────────────────────────────────────────────────
// Admins create and manage categories; any authenticated user can post threads.
// The seven seed categories are:
//   new-to-inkwell | general | community-discussion | writing-help
//   critique-discussions | genre | timezone
// ─────────────────────────────────────────────────────────────────────────────

model ThreadCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique          // display label, e.g. "New to Inkwell"
  slug        String   @unique          // url-safe key, e.g. "new-to-inkwell"
  description String?                   // optional blurb shown in the category header
  sortOrder   Int      @default(0)      // controls listing order in the UI

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads     Thread[]

  @@index([sortOrder])
  @@index([slug])
}

// ─────────────────────────────────────────────────────────────────────────────
// THREAD  — updated model (replace the existing Thread block)
// ─────────────────────────────────────────────────────────────────────────────
model Thread {
  id         Int      @id @default(autoincrement())
  authorId   Int                                         // any authenticated member
  categoryId Int?                                        // null = "uncategorised"
  title      String
  context    String                                      // body of the thread
  mediaUrl   String?                                     // optional image/attachment
  isPinned   Boolean  @default(false)                    // only admins should pin
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author    User              @relation(fields: [authorId],   references: [id], onDelete: Cascade)
  category  ThreadCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  likes     ThreadLike[]
  comments  ThreadComment[]

  @@index([authorId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([isPinned])
}

model ThreadLike {
  id       Int    @id @default(autoincrement())
  userId   Int
  threadId Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@index([threadId])
}

model ThreadComment {
  id        Int      @id @default(autoincrement())
  threadId  Int
  authorId  Int?  // nullable — preserved if user deleted
  mediaUrl   String?
  mediaUrls  Json    @default("[]")                               
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread  Thread              @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author  User?               @relation(fields: [authorId], references: [id], onDelete: SetNull)
  likes   ThreadCommentLike[]
  replies ThreadReply[]

  @@index([threadId])
  @@index([authorId])
}

model ThreadCommentLike {
  id        Int           @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime      @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment ThreadComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model ThreadReply {
  id        Int      @id @default(autoincrement())
  commentId Int
  authorId  Int?    // nullable — preserved if user deleted
  content   String
  mediaUrl   String?
  mediaUrls   Json    @default("[]")                                      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comment ThreadComment    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author  User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  likes   ThreadReplyLike[]

  @@index([commentId])
  @@index([authorId])
}

model ThreadReplyLike {
  id        Int         @id @default(autoincrement())
  userId    Int
  replyId   Int
  createdAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply ThreadReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@index([replyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DRAFT PLAN
// ─────────────────────────────────────────────────────────────────────────────
// A writer's personalised drafting plan, created through the three-step
// onboarding flow. One active plan per writer at a time (enforced in service).
// ─────────────────────────────────────────────────────────────────────────────

model DraftPlan {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique   // one active plan per writer

  // ── Step 1 — The Math Layer ──────────────────────────────────────────────
  storyTitle       String   // Step 3 — name of their story (stored here for convenience)
  premise          String   // Step 3 — story premise

  wordsWrittenSoFar   Int              // starting word count at plan creation
  targetLength        Int              // overall project goal in words
  goalType            DraftGoalType    // WORDS | CHAPTERS | SCENES
  dailyGoal           Int              // reduced expectation value (words/chapters/scenes per day)
  writingDays         DraftWritingDay[] // which days they typically write

  // ── Step 2 — The Emotional Layer ────────────────────────────────────────
  whyFinish        String   // why they want to finish the draft
  whatItMeans      String   // what finishing means to them
  dailyTreat       String   // reward for hitting daily goal
  weeklyTreat      String   // reward for hitting weekly goal
  inspirationSource String  // where they get story inspiration

  // ── Images & Characters ──────────────────────────────────────────────────
  // Up to 5 moodboard/character art images stored as URL strings in Json array
  moodboardImages  Json     @default("[]")   // String[] — up to 5 URLs

  // ── Computed / Derived ───────────────────────────────────────────────────
  estimatedDays    Int      // days to finish at daily goal, calculated at creation
  weeklyGoal       Int      // dailyGoal * active writing days per week

  // ── Status ───────────────────────────────────────────────────────────────
  isCompleted      Boolean  @default(false)
  completedAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  characters       DraftPlanCharacter[]
  progressLogs     DraftProgressLog[]

  @@index([userId])
  @@index([isCompleted])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// DRAFT PLAN CHARACTER
// Up to 5 characters per plan. Name + short description (≤50 chars).
// ─────────────────────────────────────────────────────────────────────────────

model DraftPlanCharacter {
  id          Int      @id @default(autoincrement())
  planId      Int
  name        String
  description String   // max 50 chars — enforced in service

  plan        DraftPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DRAFT PROGRESS LOG
// One row each time a writer logs their daily progress against their plan.
// ─────────────────────────────────────────────────────────────────────────────

model DraftProgressLog {
  id             Int      @id @default(autoincrement())
  planId         Int
  userId         Int
  logDate        DateTime // calendar date stored as midnight UTC
  countLogged    Int      // words/chapters/scenes logged for this day
  isPickedDay    Boolean  @default(false) // true if this log falls on one of the writer's chosen writing days
  metDailyGoal   Boolean  @default(false)
  totalSoFar     Int      // running word count after this log (wordsWrittenSoFar + all logs)
  note           String?  // optional writer note for the day

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  plan           DraftPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One log per plan per calendar day
  @@unique([planId, logDate])
  @@index([planId])
  @@index([userId])
  @@index([logDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// DRAFT WRITING DAY  (join table — which days of the week the writer is active)
// ─────────────────────────────────────────────────────────────────────────────

model DraftWritingDay {
  id              Int      @id @default(autoincrement())
  planId          Int
  day             WeekDay
  reminderTime    String   // "HH:MM" in writer's local time, display-only
  reminderTimeUTC String   // "HH:MM" UTC, used by the reminder cron
  plan            DraftPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  @@unique([planId, day])
  @@index([planId])
  @@index([reminderTimeUTC, day]) // speeds up the cron's per-minute scan
}

// ─────────────────────────────────────────────────────────────────────────────
// DIRECT MESSAGES
// A private two-person chat between any two members.
//
// Each pair of users gets exactly one Conversation room. The room is keyed on
// (userAId, userBId) where userAId is always the lower of the two user IDs —
// this canonical ordering means we can never accidentally create a duplicate
// room for the same pair.
//
// Messages live inside a Conversation. A message may optionally quote one
// earlier message (quotedMessageId) so the reader knows which message is being
// replied to. Quoted content is stored as a snapshot (quotedContent,
// quotedSenderName) so the quote still renders even if the original is deleted.
//
// Soft-delete: messages are never hard-deleted. deletedAt is set instead, and
// the API returns placeholder text ("This message was deleted") in that case.
// ─────────────────────────────────────────────────────────────────────────────

model DirectConversation {
  id      Int @id @default(autoincrement())

  // Always stored with userAId < userBId — enforced in the service layer.
  // The @@unique below prevents duplicate rooms for the same pair.
  userAId Int
  userBId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Per-participant read cursor.
  // Set to now() when that user opens the conversation.
  // A conversation is "unread" for userA if lastReadByA < the latest message's createdAt.
  lastReadByA  DateTime?
  lastReadByB  DateTime?

  userA    User             @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User             @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model DirectMessage {
  id             Int      @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String

  // Quote / reply context — optional
  // When a user replies to a specific message we store the ID of the original
  // message plus a snapshot of its text and sender name. The snapshot means
  // the quote still shows up even if the original message is later deleted.
  quotedMessageId   Int?
  quotedContent     String?  // snapshot of the quoted message's text at send time
  quotedSenderName  String?  // snapshot of the quoted sender's username at send time

  // Soft delete — we never physically remove messages
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User               @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  // Self-referential — the message being quoted (for integrity checks only;
  // the snapshot fields are what we actually render)
  quotedMessage  DirectMessage?  @relation("MessageQuote", fields: [quotedMessageId], references: [id], onDelete: SetNull)
  quotedBy       DirectMessage[] @relation("MessageQuote")

  @@index([conversationId])
  @@index([senderId])
  @@index([quotedMessageId])
}


// ─────────────────────────────────────────────────────────────────────────────
// DAYS CHALLENGE  (7-day or 15-day focused writing challenge)
// ─────────────────────────────────────────────────────────────────────────────
// Completely separate from the existing ChallengeParticipation system.
// Writers join for a specific focus (up to 2) — editing, outlining,
// brainstorming, or story development. They set a daily goal in words or
// minutes. One active challenge per writer at a time.
//
// Lifecycle:
//   ACTIVE   → writer is in progress
//   COMPLETED → writer marked done early, or hit all days
//   EXPIRED  → challenge duration passed without completion (cron sets this)
// ─────────────────────────────────────────────────────────────────────────────


model DaysChallenge {
  id               Int                    @id @default(autoincrement())
  userId           Int                    @unique

  duration         DaysChallengeDuration
  focuses          DaysChallengesFocus[]

  storyTitle       String?
  workingGoal      String
  whyNow           String

  goalType         DaysChallengeGoalType
  dailyGoal        Int

  // ── NEW: daily check-in reminder ────────────────────────────────────────
  // "HH:MM" in the writer's own local time, display-only.
  reminderTime     String                 @default("09:00")
  // "HH:MM" in UTC — derived from reminderTime + the writer's User.timezone
  // at creation/update time. This is what the cron actually matches on, so
  // it never has to do timezone math per-tick.
  reminderTimeUTC  String                 @default("09:00")

  startDate        DateTime               @default(now())
  endDate          DateTime
  completedAt      DateTime?
  expiredAt        DateTime?

  status           DaysChallengeStatus    @default(ACTIVE)

  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns         DaysChallengeCheckIn[]

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@index([createdAt])
  // NEW — speeds up the per-minute cron scan, same role as the index on
  // DraftWritingDay(reminderTimeUTC, day).
  @@index([reminderTimeUTC, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// DAYS CHALLENGE FOCUS  (join table — up to 2 focus rows per challenge)
// ─────────────────────────────────────────────────────────────────────────────

model DaysChallengesFocus {
  id          Int                   @id @default(autoincrement())
  challengeId Int
  focus       DaysChallengeFocus    // OUTLINING | BRAINSTORMING | EDITING | STORY_DEVELOPMENT

  challenge   DaysChallenge         @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, focus])    // can't pick the same focus twice
  @@index([challengeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DAYS CHALLENGE CHECK-IN
// One row per day a writer logs progress. One per challenge per calendar day
// (upsertable — they can re-log to correct their count).
// ─────────────────────────────────────────────────────────────────────────────

model DaysChallengeCheckIn {
  id            Int      @id @default(autoincrement())
  challengeId   Int
  userId        Int
  checkInDate   DateTime // midnight UTC
  countLogged   Int      // words or minutes depending on goalType
  metDailyGoal  Boolean  @default(false)
  note          String?  // optional note for the day

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  challenge     DaysChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, checkInDate])  // one check-in per challenge per day
  @@index([challengeId])
  @@index([userId])
  @@index([checkInDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// FEEDBACK HUB
// ─────────────────────────────────────────────────────────────────────────────

model FeedbackHubBootstrap {
  id        Int      @id @default(autoincrement())
  posterCount Int    @default(0)

  @@map("feedback_hub_bootstrap")
}

model FeedbackPoint {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  postingBalance Int      @default(5)
  reputation     Int      @default(5)
  usedFreePost   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackSubmission {
  id               Int              @id @default(autoincrement())
  userId           Int
  title            String
  genre            String
  summary          String
  content          String
  critiqueCount    Int              @default(0)
  status           SubmissionStatus @default(QUEUE)
  wordCountTier    WordCountTier
  actualWordCount  Int
  draftStage       DraftStage
  contentWarnings  String[]
  feedbackWanted   String[]
  pointsCost       Int
  wasFreePost      Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  isDraft          Boolean          @default(false)
  unpublishedAt    DateTime?
  writingDraft     WritingDraft?
  

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses         FeedbackResponse[]
  paragraphComments ParagraphComment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([genre])
}

model FeedbackResponse {
  id                  Int                @id @default(autoincrement())
  submissionId        Int
  criticId            Int?                                               // <-- nullable
  generalFeedback     String
  tagResponses        Json?              // optional per-tag feedback, keyed by feedbackWanted tag name
  pointsEarned        Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  critic      User?                  @relation(fields: [criticId], references: [id], onDelete: SetNull) // <-- SetNull
  upvotes     FeedbackResponseUpvote[]
  reports     CritiqueReport[]

  @@index([submissionId])
  @@index([criticId])
}

model FeedbackResponseUpvote {
  id         Int              @id @default(autoincrement())
  userId     Int
  responseId Int
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  response   FeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([userId, responseId])
  @@index([responseId])
}

model CritiqueReport {
  id          Int           @id @default(autoincrement())

  // Who filed the report
  reporterId  Int
  reporter    User          @relation("ReportSubmitter", fields: [reporterId], references: [id], onDelete: Cascade)

  // Which critique (FeedbackResponse) is being reported
  responseId  Int
  response    FeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  // Report content
  reason      String                              // e.g. "Harassment", "Spam", "Unhelpful"
  details     String?                             // optional longer description (≤ 2,000 chars)

  // Lifecycle
  status      ReportStatus  @default(PENDING)
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?

  // Admin who resolved it + optional internal notes
  resolverId  Int?
  resolver    User?         @relation("ReportResolver", fields: [resolverId], references: [id], onDelete: SetNull)
  adminNotes  String?

  // One report per user per critique
  @@unique([reporterId, responseId])

  @@index([responseId])
  @@index([reporterId])
  @@index([status])
  @@index([createdAt])
}

model ParagraphComment {
  id             Int                @id @default(autoincrement())
  submissionId   Int
  authorId       Int?                                                    // <-- nullable
  paragraphIndex Int
  content        String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author      User?                  @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull
  upvotes     ParagraphCommentUpvote[]
  replies     ParagraphCommentReply[]

  @@index([submissionId])
  @@index([submissionId, paragraphIndex])
  @@index([authorId])
}

model ParagraphCommentUpvote {
  id        Int              @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model ParagraphCommentReply {
  id        Int              @id @default(autoincrement())
  commentId Int
  authorId  Int?                                                         // <-- nullable
  content   String
  createdAt DateTime         @default(now())

  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User?            @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull

  @@index([commentId])
  @@index([authorId])
}

model WritingDraft {
  id                   Int                 @id @default(autoincrement())
  userId               Int
  title                String?
  content              String              @default("")
  wordCount            Int                 @default(0)

  // If this draft came from unpublishing a submission, link it
  sourceSubmissionId   Int?                @unique

  // ── "Staged for feedback" ───────────────────────────────────────────────
  // True when this draft was saved via the submission form's "Stage Your
  // Chapter for Feedback" button — i.e. the writer finished a chapter and
  // chose a submission tier, but didn't have enough posting points to send
  // it to the Critique Hub yet. This is what distinguishes a chapter that's
  // genuinely waiting to be unlocked from an ordinary work-in-progress draft
  // the writer just happens to be drafting on their own (those should never
  // trigger the "unlock your post" nudge).
  isStagedForFeedback   Boolean        @default(false)

  // Submission metadata captured at staging time, so the chapter can be
  // posted in one click once the writer earns enough points — no need to
  // re-fill the submission form from scratch.
  stagedGenre           String?
  stagedSummary         String?
  stagedWordCountTier   WordCountTier?
  stagedDraftStage      DraftStage?
  stagedContentWarnings String[]       @default([])
  stagedFeedbackWanted  String[]       @default([])
  stagedAt              DateTime?

  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSubmission     FeedbackSubmission? @relation(fields: [sourceSubmissionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, isStagedForFeedback])
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SPONSOR
  FOUNDING_WRITER
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum SprintType {
  WRITING
  READING
}

enum DraftStage {
  ROUGH      // be gentle
  POLISHING  // be honest
  FINAL_EDIT // be ruthless
}

enum SubmissionStatus {
  QUEUE      // waiting for first critique
  SPOTLIGHT  // received ≥1 critique, actively featured
  ARCHIVE    // received ≥3 critiques, closed for new feedback
}

enum WordCountTier {
  TIER_1000  // ≤1,000 words — costs/earns 1 pt
  TIER_2000  // ≤2,000 words — costs/earns 2 pts
  TIER_3000  // ≤3,000 words — costs/earns 3 pts
  TIER_4000  // ≤4,000 words — costs/earns 4 pts
  TIER_5000  // ≤5,000 words — costs/earns 5 pts
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum GoalType {
  WORDS
  CHAPTERS
  SCENES
  DURATION   // stored in minutes
}

enum DraftGoalType {
  WORDS
  CHAPTERS
  SCENES
}

enum WeekDay {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}


enum DaysChallengeDuration {
  SEVEN
  FIFTEEN
}

enum DaysChallengeGoalType {
  WORDS
  DURATION   // stored in minutes
}

enum DaysChallengeStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum DaysChallengeFocus {
  OUTLINING
  BRAINSTORMING
  EDITING
  STORY_DEVELOPMENT
}
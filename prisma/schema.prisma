generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String?   @unique
  password         String?
  discordId        String?   @unique
  createdVia       String    @default("site")
  avatar           String?
  bio              String?
  dateOfBirth      DateTime?
  role             Role      @default(USER)
  createdAt        DateTime  @default(now())
  timezone         String    @default("UTC")
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?

  // ── existing relations ──────────────────────────────────────────────────
  notificationPreference NotificationPreference?
  groupSprints        GroupSprint[]
  sprints             Sprint[]
  notification        Notification[]
  projects            Project[]
  todolists           Todolist[]
  notes               Note[]
  blogPostLikes       BlogPostLike[]
  blogComments        BlogComment[]
  blogReplies         BlogReply[]
  writingSnippets     WritingSnippet[]
  snippetLikes        SnippetLike[]
  snippetComments     SnippetComment[]
  snippetReplies      SnippetReply[]
  snippetCommentLikes SnippetCommentLike[]
  snippetReplyLikes   SnippetReplyLike[]
  wallPostsAuthored   WallPost[]           @relation("WallPostAuthor")
  wallPostsReceived   WallPost[]           @relation("WallPostProfile")
  wallPostLikes       WallPostLike[]
  wallPostComments    WallPostComment[]
  wallPostReplies     WallPostReply[]
  soundscapes         Soundscape[]

  // ── feedback hub relations ──────────────────────────────────────────────
  feedbackPoints              FeedbackPoint?
  feedbackSubmissions         FeedbackSubmission[]
  feedbackResponses           FeedbackResponse[]
  paragraphComments           ParagraphComment[]
  paragraphCommentReplies     ParagraphCommentReply[]
  paragraphCommentUpvotes     ParagraphCommentUpvote[]
  feedbackResponseUpvotes     FeedbackResponseUpvote[]

  discoveryStories            DiscoveryStory[]
  discoveryLikes              DiscoveryLike[]

  // ── event winners ───────────────────────────────────────────────────────
  eventWins                   EventWinner[]

  // ── emotion relations ────────────────────────────────────────────────────
  emotionLikes                EmotionLike[]
  emotionComments             EmotionComment[]
  emotionCommentLikes         EmotionCommentLike[]

  blocksMade      UserBlock[]  @relation("BlocksMade")
  blocksReceived  UserBlock[]  @relation("BlocksReceived")
}

model UserBlock {
  id        Int      @id @default(autoincrement())
  blockerId Int                          // the user who did the blocking
  blockedId Int                          // the user who was blocked
  createdAt DateTime @default(now())

  blocker   User     @relation("BlocksMade",     fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])       // can't block the same person twice
  @@index([blockerId])
  @@index([blockedId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM EVENTS  (carousel notices + days challenges)
// ─────────────────────────────────────────────────────────────────────────────
model PlatformEvent {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  bannerUrl   String?                     // optional hero image for the carousel card
  type        EventType
  // For DAYS_CHALLENGE: how many consecutive days writers must maintain
  daysTarget  Int?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Projects currently enrolled in this event (public + streak still alive)
  entries     ProjectEventEntry[]

  // Winners recorded after the event ends
  winners     EventWinner[]

  @@index([isActive])
  @@index([type])
  @@index([startDate, endDate])
}

// Join table: a public project opts into a DAYS_CHALLENGE event.
// Row is soft-deleted (disqualified = true) when the streak resets,
// which also triggers the project visibility flip to PRIVATE in the service.
model ProjectEventEntry {
  id              Int           @id @default(autoincrement())
  projectId       Int
  eventId         Int
  enrolledAt      DateTime      @default(now())
  disqualified    Boolean       @default(false)
  disqualifiedAt  DateTime?

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  event           PlatformEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // one entry per project per event
  @@unique([projectId, eventId])
  @@index([eventId])
  @@index([projectId])
  @@index([disqualified])
}

model EventWinner {
  id              Int           @id @default(autoincrement())
  eventId         Int
  userId          Int
  projectId       Int
  projectTitle    String        // snapshot — project title at time of win
  username        String        // snapshot — in case username ever changes
  avatar          String?       // snapshot
  finalStreak     Int           // how many days they maintained
  totalWords      Int           @default(0)
  totalChapters   Int           @default(0)
  totalScenes     Int           @default(0)
  totalMinutes    Int           @default(0)
  challengeRole   ChallengeRole // the badge/role awarded
  createdAt       DateTime      @default(now())

  event           PlatformEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])   // one winner record per user per event
  @@index([eventId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id               Int       @id @default(autoincrement())
  userId           Int
  title            String
  description      String?
  link             String?
  genre            String?
  visibility       Visibility    @default(PRIVATE)

  // ── Writing phase ──────────────────────────────────────────────────────
  phase            WritingPhase  @default(DRAFTING)

  // ── Word / chapter / scene targets ────────────────────────────────────
  targetWordCount  Int?
  currentWordCount Int        @default(0)
  targetChapters   Int?
  currentChapters  Int        @default(0)
  targetScenes     Int?
  currentScenes    Int        @default(0)

  // ── Session goal ───────────────────────────────────────────────────────
  sessionGoalType     SessionGoalType?
  sessionGoalCount    Int?
  currentSessionCount Int    @default(0)
  lastSessionReset    DateTime?

  // ── Consecutive-days streak tracker ───────────────────────────────────
  consecutiveDaysTarget Int?
  currentStreak         Int       @default(0)
  lastLogDate           DateTime?

  // ── Deadline / schedule ────────────────────────────────────────────────
  deadline         DateTime?
  daysPerWeek      Int           @default(5)
  status           ProjectStatus @default(IN_PROGRESS)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordLogs         ProjectWordLog[]
  progressLogs     ProjectProgressLog[]
  sessionLogs      ProjectSessionLog[]
  dayLogs          ProjectDayLog[]
  todolists        Todolist[]
  notes            Note[]
  sprints          Sprint[]
  eventEntries     ProjectEventEntry[]

  @@index([userId])
  @@index([visibility])
}

// ─── Day Log (streak system) ──────────────────────────────────────────────────
model ProjectDayLog {
  id             Int      @id @default(autoincrement())
  projectId      Int
  userId         Int
  logDate        DateTime
  wordsLogged    Int      @default(0)
  chaptersLogged Int      @default(0)
  scenesLogged   Int      @default(0)
  minutesLogged  Int      @default(0)
  streakAtLog    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, logDate])
  @@index([projectId])
  @@index([userId])
  @@index([logDate])
}

model ProjectWordLog {
  id          Int      @id @default(autoincrement())
  projectId   Int
  userId      Int
  wordsAdded  Int
  loggedAt    DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([loggedAt])
}

model ProjectProgressLog {
  id             Int      @id @default(autoincrement())
  projectId      Int
  userId         Int
  chaptersAdded  Int      @default(0)
  scenesAdded    Int      @default(0)
  loggedAt       DateTime @default(now())

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([loggedAt])
}

model ProjectSessionLog {
  id              Int      @id @default(autoincrement())
  projectId       Int
  userId          Int
  loggedAt        DateTime @default(now())
  wordsWritten    Int?
  chaptersWritten Int?
  scenesWritten   Int?
  minutesWritten  Int?

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([loggedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// TODOLIST & NOTES
// ─────────────────────────────────────────────────────────────────────────────

model Todolist {
  id           Int      @id @default(autoincrement())
  task         String
  index        Int
  markComplete Boolean  @default(false)
  projectId    Int
  userId       Int
  createdAt    DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([index])
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String?
  note      String
  projectId Int
  userId    Int
  createdAt DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// GROUP SPRINT & SPRINT
// ─────────────────────────────────────────────────────────────────────────────

model GroupSprint {
  id                Int        @id @default(autoincrement())
  userId            Int
  duration          Int
  totalWordsWritten Int        @default(0)
  liveKitRoomName   String?
  visibility        Visibility @default(PUBLIC)
  sprintType        SprintType @default(WRITING)
  startedAt         DateTime   @default(now())
  completedAt       DateTime?
  isActive          Boolean    @default(true)

  sprints           Sprint[]
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([startedAt])
  @@index([visibility])
}

model Sprint {
  id            Int          @id @default(autoincrement())
  userId        Int
  groupSprintId Int?
  soundscapeId  Int?
  projectId     Int?
  checkin       String?
  startWords    Int          @default(0)
  wordsWritten  Int          @default(0)
  deletedWords  Int          @default(0)
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  isActive      Boolean      @default(true)

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupSprint   GroupSprint? @relation(fields: [groupSprintId], references: [id], onDelete: SetNull)
  soundscape    Soundscape?  @relation(fields: [soundscapeId], references: [id], onDelete: SetNull)
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([groupSprintId])
  @@index([isActive])
  @@index([soundscapeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SOUNDSCAPE
// ─────────────────────────────────────────────────────────────────────────────

model Soundscape {
  id            Int       @id @default(autoincrement())
  name          String
  creatorName   String?
  fileUrl       String
  contributedBy Int
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  contributor   User      @relation(fields: [contributedBy], references: [id], onDelete: Cascade)
  sprints       Sprint[]

  @@index([contributedBy])
  @@index([isApproved])
}

// ─────────────────────────────────────────────────────────────────────────────
// WEEKLY SCHEDULE
// ─────────────────────────────────────────────────────────────────────────────

model WeeklySchedule {
  id          Int      @id @default(autoincrement())
  weekStart   DateTime @unique
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions ScheduledSession[]

  @@index([weekStart])
  @@index([isActive])
}

model ScheduledSession {
  id          Int      @id @default(autoincrement())
  scheduleId  Int
  dayOfWeek   Int
  time        String
  label       String?
  isDone      Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  schedule WeeklySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([dayOfWeek])
  @@index([isDone])
}

// ─────────────────────────────────────────────────────────────────────────────
// WRITING SNIPPET
// ─────────────────────────────────────────────────────────────────────────────

model WritingSnippet {
  id         Int           @id @default(autoincrement())
  userId     Int
  context    String?
  mediaUrl   String?
  sourceType SnippetSource @default(POST_SPRINT)
  tags       String?
  createdAt  DateTime      @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes      SnippetLike[]
  comments   SnippetComment[]

  @@index([userId])
  @@index([createdAt])
}

model SnippetLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  snippetId Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet   WritingSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])
  @@index([snippetId])
}

// NOTE: userId is now nullable + SetNull so comments survive account deletion.
// The UI should render "[deleted]" when userId is null.
model SnippetComment {
  id        Int            @id @default(autoincrement())
  userId    Int?                                                          // <-- nullable
  snippetId Int
  content   String
  createdAt DateTime       @default(now())

  likes     SnippetCommentLike[]
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull) // <-- SetNull
  snippet   WritingSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  replies   SnippetReply[]

  @@index([snippetId])
  @@index([userId])
}

// NOTE: userId nullable + SetNull — same reasoning as SnippetComment.
model SnippetReply {
  id        Int            @id @default(autoincrement())
  userId    Int?                                                          // <-- nullable
  commentId Int
  content   String
  createdAt DateTime       @default(now())

  likes     SnippetReplyLike[]
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull) // <-- SetNull
  comment   SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
}

model SnippetCommentLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  commentId Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model SnippetReplyLike {
  id      Int          @id @default(autoincrement())
  userId  Int
  replyId Int
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply   SnippetReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@index([replyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// QUOTES, SUBSCRIPTIONS, NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id           Int      @id @default(autoincrement())
  userId       Int
  subscription Json
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  username  String
  userId    Int
  message   String?
  link      String?
  read      Boolean? @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model NotificationPreference {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferences Json     @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────────────────────────────────────

model BlogPost {
  id        Int            @id @default(autoincrement())
  title     String?
  content   String
  mediaUrl  String?
  link      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  likes     BlogPostLike[]
  comments  BlogComment[]

  @@index([createdAt])
}

model BlogPostLike {
  id         Int      @id @default(autoincrement())
  userId     Int
  blogPostId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([userId, blogPostId])
  @@index([blogPostId])
}

// NOTE: authorId nullable + SetNull — blog comments survive account deletion.
model BlogComment {
  id         Int         @id @default(autoincrement())
  blogPostId Int
  authorId   Int?                                                         // <-- nullable
  content    String
  createdAt  DateTime    @default(now())
  post       BlogPost    @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  author     User?       @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull
  replies    BlogReply[]

  @@index([blogPostId])
  @@index([authorId])
}

// NOTE: authorId nullable + SetNull — blog replies survive account deletion.
model BlogReply {
  id        Int         @id @default(autoincrement())
  commentId Int
  authorId  Int?                                                          // <-- nullable
  content   String
  createdAt DateTime    @default(now())
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User?       @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull

  @@index([commentId])
  @@index([authorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WALL POST
// ─────────────────────────────────────────────────────────────────────────────

// NOTE: authorId nullable + SetNull — wall posts written by a deleted user are
// preserved on the recipient's wall but show "[deleted]" as the author.
// wallPostsReceived (profileId) stays Cascade: if your profile is gone, your
// wall goes with it.
model WallPost {
  id        Int      @id @default(autoincrement())
  authorId  Int?                                                          // <-- nullable
  profileId Int
  content   String
  createdAt DateTime @default(now())

  author   User?             @relation("WallPostAuthor", fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull
  profile  User              @relation("WallPostProfile", fields: [profileId], references: [id], onDelete: Cascade)
  likes    WallPostLike[]
  comments WallPostComment[]

  @@index([profileId])
  @@index([authorId])
}

model WallPostLike {
  id         Int      @id @default(autoincrement())
  userId     Int
  wallPostId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallPost   WallPost @relation(fields: [wallPostId], references: [id], onDelete: Cascade)

  @@unique([userId, wallPostId])
  @@index([wallPostId])
}

// NOTE: userId nullable + SetNull — wall post comments survive account deletion.
model WallPostComment {
  id         Int      @id @default(autoincrement())
  userId     Int?                                                         // <-- nullable
  wallPostId Int
  content    String
  createdAt  DateTime @default(now())

  user     User?           @relation(fields: [userId], references: [id], onDelete: SetNull) // <-- SetNull
  wallPost WallPost        @relation(fields: [wallPostId], references: [id], onDelete: Cascade)
  replies  WallPostReply[]

  @@index([wallPostId])
  @@index([userId])
}

// NOTE: userId nullable + SetNull — wall post replies survive account deletion.
model WallPostReply {
  id        Int             @id @default(autoincrement())
  userId    Int?                                                          // <-- nullable
  commentId Int
  content   String
  createdAt DateTime        @default(now())

  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull) // <-- SetNull
  comment WallPostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FEEDBACK HUB
// ─────────────────────────────────────────────────────────────────────────────

model FeedbackHubBootstrap {
  id        Int      @id @default(autoincrement())
  posterCount Int    @default(0)

  @@map("feedback_hub_bootstrap")
}

model FeedbackPoint {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  postingBalance Int      @default(5)
  reputation     Int      @default(5)
  usedFreePost   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackSubmission {
  id               Int             @id @default(autoincrement())
  userId           Int
  title            String
  genre            String
  summary          String
  content          String
  critiqueCount    Int      @default(0)
  isOutdated       Boolean  @default(false)
  wordCountTier    WordCountTier
  actualWordCount  Int
  draftStage       DraftStage
  contentWarnings  String[]
  feedbackWanted   String[]
  pointsCost       Int
  wasFreePost      Boolean         @default(false)
  isOpen           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses         FeedbackResponse[]
  paragraphComments ParagraphComment[]

  @@index([userId])
  @@index([isOpen])
  @@index([createdAt])
  @@index([genre])
}

// NOTE: criticId nullable + SetNull — full critiques survive account deletion.
// The content (ratings + written feedback) is valuable to the submission author
// and should not vanish just because the critic left.
model FeedbackResponse {
  id                  Int                @id @default(autoincrement())
  submissionId        Int
  criticId            Int?                                               // <-- nullable
  overallRating       Int?
  clarityRating       Int?
  pacingRating        Int?
  believabilityRating Int?
  generalFeedback     String
  pointsEarned        Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  critic      User?                  @relation(fields: [criticId], references: [id], onDelete: SetNull) // <-- SetNull
  upvotes     FeedbackResponseUpvote[]

  // One full response per critic per submission
  // @@unique([submissionId, criticId]) -- removed: criticId is now nullable,
  // so the unique constraint would allow multiple null-critic rows. If you need
  // to prevent duplicates before deletion, enforce it at the application layer.
  @@index([submissionId])
  @@index([criticId])
}

model FeedbackResponseUpvote {
  id         Int              @id @default(autoincrement())
  userId     Int
  responseId Int
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  response   FeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([userId, responseId])
  @@index([responseId])
}

// NOTE: authorId nullable + SetNull — paragraph comments survive account deletion.
model ParagraphComment {
  id             Int                @id @default(autoincrement())
  submissionId   Int
  authorId       Int?                                                    // <-- nullable
  paragraphIndex Int
  content        String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author      User?                  @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull
  upvotes     ParagraphCommentUpvote[]
  replies     ParagraphCommentReply[]

  @@index([submissionId])
  @@index([submissionId, paragraphIndex])
  @@index([authorId])
}

model ParagraphCommentUpvote {
  id        Int              @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

// NOTE: authorId nullable + SetNull — paragraph comment replies survive account deletion.
model ParagraphCommentReply {
  id        Int              @id @default(autoincrement())
  commentId Int
  authorId  Int?                                                         // <-- nullable
  content   String
  createdAt DateTime         @default(now())

  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User?            @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull

  @@index([commentId])
  @@index([authorId])
}

model DiscoveryStory {
  id              Int      @id @default(autoincrement())
  userId          Int
  title           String
  genre           String
  synopsis        String
  firstChapterTitle String?
  firstChapter    String
  coverUrl        String?
  authorName      String
  recommendedBy   String?
  platform        String
  platformLink    String
  contentWarnings String[] @default([])
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes  DiscoveryLike[]

  @@index([userId])
  @@index([isApproved])
  @@index([createdAt])
  @@index([genre])
}

model DiscoveryLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  storyId   Int
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  story DiscoveryStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([storyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRAFT LEARNING — Emotion Thesaurus daily feature
// ─────────────────────────────────────────────────────────────────────────────

model EmotionEntry {
  id          Int      @id @default(autoincrement())
  emotion     String   // e.g. "Anxiety"
  cues        String[] // physical signal phrases
  scheduledAt DateTime @unique // which day this emotion is shown
  createdAt   DateTime @default(now())

  likes       EmotionLike[]
  comments    EmotionComment[]

  @@index([scheduledAt])
}

model EmotionTemplate {
  id        Int      @id @default(autoincrement())
  emotion   String
  cues      String[]
  sortOrder Int      @unique  // 1, 2, 3 … determines the cycle order

  @@index([sortOrder])
}

model EmotionLike {
  id      Int          @id @default(autoincrement())
  userId  Int
  entryId Int
  createdAt DateTime   @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry   EmotionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([userId, entryId])
  @@index([entryId])
}

model EmotionComment {
  id        Int          @id @default(autoincrement())
  entryId   Int
  authorId  Int?
  content   String
  isPinned  Boolean      @default(false)
  createdAt DateTime     @default(now())

  entry   EmotionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  author  User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  likes   EmotionCommentLike[]

  @@index([entryId])
  @@index([authorId])
}

model EmotionCommentLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime       @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment EmotionComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}


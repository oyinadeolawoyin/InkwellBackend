generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String?   @unique
  password         String?
  discordId        String?   @unique
  createdVia       String    @default("site")
  avatar           String?
  bio              String?
  role             Role      @default(USER)
  createdAt        DateTime  @default(now())
  timezone         String    @default("UTC")
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  groupSprints        GroupSprint[]
  sprints             Sprint[]
  notification        Notification[]
  projects            Project[]
  todolists           Todolist[]
  notes               Note[]
  quoteLikes          QuoteLike[]
  blogPostLikes       BlogPostLike[]
  blogComments        BlogComment[]
  blogReplies         BlogReply[]
  writingSnippets     WritingSnippet[]
  snippetLikes        SnippetLike[]
  snippetComments     SnippetComment[]
  snippetReplies      SnippetReply[]
  snippetCommentLikes SnippetCommentLike[]
  snippetReplyLikes   SnippetReplyLike[]
  wallPostsAuthored   WallPost[]           @relation("WallPostAuthor")
  wallPostsReceived   WallPost[]           @relation("WallPostProfile")
  wallPostLikes       WallPostLike[]
  wallPostComments    WallPostComment[]
  wallPostReplies     WallPostReply[]
  soundscapes         Soundscape[]

  feedbackPoints              FeedbackPoint?
  feedbackSubmissions         FeedbackSubmission[]
  feedbackResponses           FeedbackResponse[]
  paragraphComments           ParagraphComment[]
  paragraphCommentReplies     ParagraphCommentReply[]
  paragraphCommentUpvotes     ParagraphCommentUpvote[]
  feedbackResponseUpvotes     FeedbackResponseUpvote[]

  discoveryStories            DiscoveryStory[]
  discoveryLikes              DiscoveryLike[]

  subscriptions               Subscription[]
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id               Int       @id @default(autoincrement())
  userId           Int
  title            String
  description      String?
  link             String?
  genre            String?
  visibility       Visibility @default(PRIVATE)

  // ── Tracker ──────────────────────────────────────────────────────────────
  trackerType         TrackerType   @default(WORD_COUNT)
  targetWordCount     Int?
  currentWordCount    Int           @default(0)
  targetChapters      Int?
  currentChapters     Int           @default(0)
  targetScenes        Int?
  currentScenes       Int           @default(0)
  sessionGoalType     SessionGoalType?
  sessionGoalCount    Int?
  currentSessionCount Int           @default(0)
  lastSessionReset    DateTime?

  // Streak tracker (used when trackerType = STREAK)
  streakGoal          Int?          // e.g. 5, 7, 10 consecutive days
  currentStreak       Int           @default(0)
  longestStreak       Int           @default(0)
  lastLoggedDate      DateTime?     // UTC midnight of last log day
  streakBrokenAt      DateTime?

  // ── Writing phase ─────────────────────────────────────────────────────────
  phase               WritingPhase  @default(DRAFTING)

  deadline         DateTime?
  daysPerWeek      Int           @default(5)
  status           ProjectStatus @default(IN_PROGRESS)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordLogs         ProjectWordLog[]
  progressLogs     ProjectProgressLog[]
  sessionLogs      ProjectSessionLog[]
  dailyLogs        ProjectDailyLog[]
  eventParticipations EventParticipation[]
  todolists        Todolist[]
  notes            Note[]
  sprints          Sprint[]

  @@index([userId])
  @@index([visibility])
}

model ProjectWordLog {
  id          Int      @id @default(autoincrement())
  projectId   Int
  userId      Int
  wordsAdded  Int
  loggedAt    DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([loggedAt])
}

model ProjectProgressLog {
  id             Int      @id @default(autoincrement())
  projectId      Int
  userId         Int
  chaptersAdded  Int      @default(0)
  scenesAdded    Int      @default(0)
  loggedAt       DateTime @default(now())

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([loggedAt])
}

model ProjectSessionLog {
  id         Int      @id @default(autoincrement())
  projectId  Int
  userId     Int
  loggedAt   DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([loggedAt])
}

// One unified daily log — one row per project per calendar day
model ProjectDailyLog {
  id            Int      @id @default(autoincrement())
  projectId     Int
  userId        Int
  logDate       DateTime // UTC midnight of the log day
  wordsAdded    Int      @default(0)
  chaptersAdded Int      @default(0)
  scenesAdded   Int      @default(0)
  sessionsAdded Int      @default(0)
  dayLogged     Boolean  @default(true) // always true — for streak type projects
  streakAtLog   Int      @default(0)

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, logDate])
  @@index([projectId])
  @@index([logDate])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WRITING EVENTS
// ─────────────────────────────────────────────────────────────────────────────

model WritingEvent {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  durationDays Int      // 5, 7, or 10
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  participations EventParticipation[]

  @@index([isActive])
  @@index([startDate])
}

model EventParticipation {
  id            Int      @id @default(autoincrement())
  eventId       Int
  projectId     Int
  userId        Int
  currentStreak Int      @default(0)
  completed     Boolean  @default(false)
  joinedAt      DateTime @default(now())
  completedAt   DateTime?

  event   WritingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([eventId, projectId])
  @@index([eventId])
  @@index([projectId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// TODOLIST & NOTES
// ─────────────────────────────────────────────────────────────────────────────

model Todolist {
  id           Int      @id @default(autoincrement())
  task         String
  index        Int
  markComplete Boolean  @default(false)
  projectId    Int
  userId       Int
  createdAt    DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([index])
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String?
  note      String
  projectId Int
  userId    Int
  createdAt DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// GROUP SPRINT & SPRINT
// ─────────────────────────────────────────────────────────────────────────────

model GroupSprint {
  id                Int        @id @default(autoincrement())
  userId            Int
  duration          Int
  totalWordsWritten Int        @default(0)
  liveKitRoomName   String?
  visibility        Visibility @default(PUBLIC)
  sprintType        SprintType @default(WRITING)
  startedAt         DateTime   @default(now())
  completedAt       DateTime?
  isActive          Boolean    @default(true)

  sprints           Sprint[]
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([startedAt])
  @@index([visibility])
}

model Sprint {
  id            Int          @id @default(autoincrement())
  userId        Int
  groupSprintId Int?
  soundscapeId  Int?
  projectId     Int?
  checkin       String?
  startWords    Int          @default(0)
  wordsWritten  Int          @default(0)
  deletedWords  Int          @default(0)
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  isActive      Boolean      @default(true)

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupSprint   GroupSprint? @relation(fields: [groupSprintId], references: [id], onDelete: SetNull)
  soundscape    Soundscape?  @relation(fields: [soundscapeId], references: [id], onDelete: SetNull)
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([groupSprintId])
  @@index([isActive])
  @@index([soundscapeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SOUNDSCAPE
// ─────────────────────────────────────────────────────────────────────────────

model Soundscape {
  id            Int       @id @default(autoincrement())
  name          String
  creatorName   String?
  fileUrl       String
  contributedBy Int
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  user     User     @relation(fields: [contributedBy], references: [id], onDelete: Cascade)
  sprints  Sprint[]

  @@index([contributedBy])
  @@index([isApproved])
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS & SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  username  String
  message   String
  link      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id           Int      @id @default(autoincrement())
  userId       Int
  subscription Json
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// QUOTES
// ─────────────────────────────────────────────────────────────────────────────

model Quote {
  id        Int         @id @default(autoincrement())
  text      String
  author    String?
  category  String?
  createdAt DateTime    @default(now())

  likes     QuoteLike[]

  @@index([createdAt])
}

model QuoteLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  quoteId   Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([userId, quoteId])
  @@index([quoteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────────────────────────────────────

model BlogPost {
  id          Int            @id @default(autoincrement())
  title       String
  content     String
  coverUrl    String?
  authorName  String
  published   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  likes       BlogPostLike[]
  comments    BlogComment[]

  @@index([published])
  @@index([createdAt])
}

model BlogPostLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model BlogComment {
  id        Int            @id @default(autoincrement())
  userId    Int
  postId    Int
  content   String
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      BlogPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  replies   BlogReply[]

  @@index([postId])
}

model BlogReply {
  id        Int         @id @default(autoincrement())
  userId    Int
  commentId Int
  content   String
  createdAt DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WRITING SNIPPETS
// ─────────────────────────────────────────────────────────────────────────────

model WritingSnippet {
  id          Int            @id @default(autoincrement())
  userId      Int
  content     String
  source      SnippetSource
  sprintId    Int?
  createdAt   DateTime       @default(now())

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes       SnippetLike[]
  comments    SnippetComment[]

  @@index([userId])
  @@index([createdAt])
}

model SnippetLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  snippetId Int
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet   WritingSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])
  @@index([snippetId])
}

model SnippetComment {
  id        Int                  @id @default(autoincrement())
  userId    Int
  snippetId Int
  content   String
  createdAt DateTime             @default(now())

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet   WritingSnippet       @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  likes     SnippetCommentLike[]
  replies   SnippetReply[]

  @@index([snippetId])
}

model SnippetCommentLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model SnippetReply {
  id        Int            @id @default(autoincrement())
  userId    Int
  commentId Int
  content   String
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}

model SnippetReplyLike {
  id        Int          @id @default(autoincrement())
  userId    Int
  replyId   Int
  createdAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply     SnippetReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@index([replyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WALL POSTS
// ─────────────────────────────────────────────────────────────────────────────

model WallPost {
  id          Int              @id @default(autoincrement())
  authorId    Int
  profileId   Int
  content     String
  createdAt   DateTime         @default(now())

  author      User             @relation("WallPostAuthor",  fields: [authorId],  references: [id], onDelete: Cascade)
  profile     User             @relation("WallPostProfile", fields: [profileId], references: [id], onDelete: Cascade)
  likes       WallPostLike[]
  comments    WallPostComment[]

  @@index([profileId])
  @@index([authorId])
}

model WallPostLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      WallPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model WallPostComment {
  id        Int               @id @default(autoincrement())
  userId    Int
  postId    Int
  content   String
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      WallPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  replies   WallPostReply[]

  @@index([postId])
}

model WallPostReply {
  id        Int             @id @default(autoincrement())
  userId    Int
  commentId Int
  content   String
  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   WallPostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FEEDBACK HUB
// ─────────────────────────────────────────────────────────────────────────────

model FeedbackHubBootstrap {
  id          Int @id @default(autoincrement())
  posterCount Int @default(0)

  @@map("feedback_hub_bootstrap")
}

model FeedbackPoint {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  postingBalance Int      @default(5)
  reputation     Int      @default(5)
  usedFreePost   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackSubmission {
  id               Int             @id @default(autoincrement())
  userId           Int
  title            String
  genre            String
  summary          String
  content          String
  wordCountTier    WordCountTier
  actualWordCount  Int
  draftStage       DraftStage
  contentWarnings  String[]
  feedbackWanted   String[]
  pointsCost       Int
  wasFreePost      Boolean         @default(false)
  isOpen           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses         FeedbackResponse[]
  paragraphComments ParagraphComment[]

  @@index([userId])
  @@index([isOpen])
  @@index([createdAt])
  @@index([genre])
}

model FeedbackResponse {
  id                  Int                @id @default(autoincrement())
  submissionId        Int
  criticId            Int
  overallRating       Int
  clarityRating       Int
  pacingRating        Int
  believabilityRating Int
  generalFeedback     String
  pointsEarned        Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  critic      User                   @relation(fields: [criticId], references: [id], onDelete: Cascade)
  upvotes     FeedbackResponseUpvote[]

  @@unique([submissionId, criticId])
  @@index([submissionId])
  @@index([criticId])
}

model FeedbackResponseUpvote {
  id         Int              @id @default(autoincrement())
  userId     Int
  responseId Int
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  response   FeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([userId, responseId])
  @@index([responseId])
}

model ParagraphComment {
  id             Int                @id @default(autoincrement())
  submissionId   Int
  authorId       Int
  paragraphIndex Int
  content        String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author      User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  upvotes     ParagraphCommentUpvote[]
  replies     ParagraphCommentReply[]

  @@index([submissionId])
  @@index([submissionId, paragraphIndex])
  @@index([authorId])
}

model ParagraphCommentUpvote {
  id        Int              @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model ParagraphCommentReply {
  id        Int              @id @default(autoincrement())
  commentId Int
  authorId  Int
  content   String
  createdAt DateTime         @default(now())

  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([authorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DISCOVERY
// ─────────────────────────────────────────────────────────────────────────────

model DiscoveryStory {
  id              Int      @id @default(autoincrement())
  userId          Int
  title           String
  genre           String
  synopsis        String
  firstChapter    String
  coverUrl        String?
  authorName      String
  recommendedBy   String?
  platform        String
  platformLink    String
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes  DiscoveryLike[]

  @@index([userId])
  @@index([isApproved])
  @@index([createdAt])
  @@index([genre])
}

model DiscoveryLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  storyId   Int
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  story DiscoveryStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([storyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SPONSOR
  FOUNDING_WRITER
}

enum SnippetSource {
  POST_SPRINT
  STANDALONE
}

enum SessionGoalType {
  DAILY
  WEEKLY
  MONTHLY
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum SprintType {
  WRITING
  READING
}

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  ABANDONED
}

enum DraftStage {
  ROUGH
  POLISHING
  FINAL_EDIT
}

enum WordCountTier {
  TIER_1000
  TIER_2000
  TIER_3000
  TIER_4000
}

enum TrackerType {
  WORD_COUNT
  CHAPTERS
  SCENES
  SESSIONS
  STREAK
}

enum WritingPhase {
  BRAINSTORMING
  PLANNING
  DRAFTING
  EDITING
}
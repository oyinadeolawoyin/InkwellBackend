generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String?   @unique
  password         String?
  discordId        String?   @unique
  createdVia       String    @default("site")
  avatar           String?
  bio              String?
  dateOfBirth      DateTime?
  role             Role      @default(USER)
  createdAt        DateTime  @default(now())
  timezone         String    @default("UTC")
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?

  referralSource   String?   // "how did you find us" answer at signup
  socialLinks      Json?     // [{ platform: "Twitter", url: "https://..." }, ...]

  challengeLongestStreak   Int     @default(0)  

  // ── existing relations ──────────────────────────────────────────────────
  challengeParticipations  ChallengeParticipation[]
  challengeCheckIns        ChallengeCheckIn[]

  notificationPreference NotificationPreference?
  sprintReminderOptIn    SprintReminderOptIn?  
  groupSprints        GroupSprint[]
  sprints             Sprint[]
  notification        Notification[]
  blogPostLikes       BlogPostLike[]
  blogComments        BlogComment[]
  blogReplies         BlogReply[]
  writingSnippets     WritingSnippet[]
  snippetLikes        SnippetLike[]
  snippetComments     SnippetComment[]
  snippetReplies      SnippetReply[]
  snippetCommentLikes SnippetCommentLike[]
  snippetReplyLikes   SnippetReplyLike[]
  wallPostsAuthored   WallPost[]           @relation("WallPostAuthor")
  wallPostsReceived   WallPost[]           @relation("WallPostProfile")
  wallPostLikes       WallPostLike[]
  wallPostComments    WallPostComment[]
  wallPostReplies     WallPostReply[]
  soundscapes         Soundscape[]
  writingDrafts       WritingDraft[]

  // ── feedback hub relations ──────────────────────────────────────────────
  feedbackPoints              FeedbackPoint?
  feedbackSubmissions         FeedbackSubmission[]
  feedbackResponses           FeedbackResponse[]
  paragraphComments           ParagraphComment[]
  paragraphCommentReplies     ParagraphCommentReply[]
  paragraphCommentUpvotes     ParagraphCommentUpvote[]
  feedbackResponseUpvotes     FeedbackResponseUpvote[]
  critiqueReportsSubmitted    CritiqueReport[]  @relation("ReportSubmitter")
  critiqueReportsResolved     CritiqueReport[]  @relation("ReportResolver")

  discoveryStories            DiscoveryStory[]
  discoveryLikes              DiscoveryLike[]

  // ── emotion relations ────────────────────────────────────────────────────
  emotionLikes                EmotionLike[]
  emotionComments             EmotionComment[]
  emotionCommentLikes         EmotionCommentLike[]

  blocksMade      UserBlock[]  @relation("BlocksMade")
  blocksReceived  UserBlock[]  @relation("BlocksReceived")

  // ── thread relations ─────────────────────────────────────────────────────
  threads             Thread[]
  threadLikes         ThreadLike[]
  threadComments      ThreadComment[]
  threadCommentLikes  ThreadCommentLike[]
  threadReplies       ThreadReply[]
  threadReplyLikes    ThreadReplyLike[]
}

model UserBlock {
  id        Int      @id @default(autoincrement())
  blockerId Int                          // the user who did the blocking
  blockedId Int                          // the user who was blocked
  createdAt DateTime @default(now())

  blocker   User     @relation("BlocksMade",     fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])       // can't block the same person twice
  @@index([blockerId])
  @@index([blockedId])
}

model ChallengeParticipation {
  id               Int           @id @default(autoincrement())
  userId           Int           @unique   // one active slot per writer at a time (enforced in service)
 
  // Goal the writer set when they joined
  goalValue        Int         @default(0) // e.g. 500 (words), 2 (chapters), 3 (scenes), 30 (minutes)
  goalType         GoalType    @default(WORDS)  // WORDS | CHAPTERS | SCENES | DURATION
 
  // Streak tracking
  currentStreak    Int           @default(0)
  longestStreak    Int           @default(0)   // local copy for leaderboard queries
  missedDaysInRow  Int           @default(0)
  lastCheckInDate  DateTime?
 
  joinedAt         DateTime      @default(now())
  isActive         Boolean       @default(true)
  remindersEnabled Boolean       @default(true)
 
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns  ChallengeCheckIn[]
 
  @@index([userId])
  @@index([isActive])
  @@index([currentStreak])
  @@index([joinedAt])
}

// One row per day a writer logs progress in a challenge.
model ChallengeCheckIn {
  id              Int      @id @default(autoincrement())
  participationId Int
  userId          Int
  checkInDate     DateTime                       // the calendar date (stored as midnight UTC)
  countLogged     Int                            // words or chapters logged for this day
  metDailyGoal    Boolean  @default(false)       // true if countLogged >= participation.dailyGoal
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  participation  ChallengeParticipation  @relation(fields: [participationId], references: [id], onDelete: Cascade)
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Only one check-in entry per participation per day
  @@unique([participationId, checkInDate])
  @@index([participationId])
  @@index([userId])
  @@index([checkInDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// GROUP SPRINT & SPRINT
// ─────────────────────────────────────────────────────────────────────────────

model GroupSprint {
  id                Int        @id @default(autoincrement())
  userId            Int
  duration          Int
  totalWordsWritten Int        @default(0)
  liveKitRoomName   String?
  visibility        Visibility @default(PUBLIC)
  sprintType        SprintType @default(WRITING)
  startedAt         DateTime   @default(now())
  completedAt       DateTime?
  isActive          Boolean    @default(true)

  sprints           Sprint[]
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([startedAt])
  @@index([visibility])
}

model Sprint {
  id            Int          @id @default(autoincrement())
  userId        Int
  groupSprintId Int?
  soundscapeId  Int?
  projectId     Int?
  checkin       String?
  startWords    Int          @default(0)
  wordsWritten  Int          @default(0)
  deletedWords  Int          @default(0)
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  isActive      Boolean      @default(true)

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupSprint   GroupSprint? @relation(fields: [groupSprintId], references: [id], onDelete: SetNull)
  soundscape    Soundscape?  @relation(fields: [soundscapeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([groupSprintId])
  @@index([isActive])
  @@index([soundscapeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SOUNDSCAPE
// ─────────────────────────────────────────────────────────────────────────────

model Soundscape {
  id            Int       @id @default(autoincrement())
  name          String
  creatorName   String?
  fileUrl       String
  contributedBy Int
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  contributor   User      @relation(fields: [contributedBy], references: [id], onDelete: Cascade)
  sprints       Sprint[]

  @@index([contributedBy])
  @@index([isApproved])
}

// ─────────────────────────────────────────────────────────────────────────────
// WRITING SNIPPET
// ─────────────────────────────────────────────────────────────────────────────

model WritingSnippet {
  id         Int           @id @default(autoincrement())
  userId     Int
  context    String?
  mediaUrl   String?
  sourceType SnippetSource @default(POST_SPRINT)
  tags       String?
  createdAt  DateTime      @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes      SnippetLike[]
  comments   SnippetComment[]

  @@index([userId])
  @@index([createdAt])
}

model SnippetLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  snippetId Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet   WritingSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])
  @@index([snippetId])
}

model SnippetComment {
  id        Int            @id @default(autoincrement())
  userId    Int?                                                          // <-- nullable
  snippetId Int
  content   String
  createdAt DateTime       @default(now())

  likes     SnippetCommentLike[]
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull) // <-- SetNull
  snippet   WritingSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  replies   SnippetReply[]

  @@index([snippetId])
  @@index([userId])
}


model SnippetReply {
  id        Int            @id @default(autoincrement())
  userId    Int?                                                          // <-- nullable
  commentId Int
  content   String
  createdAt DateTime       @default(now())

  likes     SnippetReplyLike[]
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull) // <-- SetNull
  comment   SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
}

model SnippetCommentLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  commentId Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model SnippetReplyLike {
  id      Int          @id @default(autoincrement())
  userId  Int
  replyId Int
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply   SnippetReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@index([replyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// QUOTES, SUBSCRIPTIONS, NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// SPRINT REMINDER OPT-IN
//
// Tracks which users want to be notified before the weekly Friday sprint.
// One row per user — upserted when they toggle the checkbox in the UI.
// ─────────────────────────────────────────────────────────────────────────────

model SprintReminderOptIn {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique          // one row per user
  optedIn               Boolean  @default(true)   // false = soft-disabled without deleting the row
  reminderMinutesBefore Int      @default(30)      // future-proofing: user-configurable lead time
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([optedIn])   // the cron job filters on this
}

model Subscription {
  id           Int      @id @default(autoincrement())
  userId       Int
  subscription Json
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  username  String
  userId    Int
  message   String?
  link      String?
  read      Boolean? @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model NotificationPreference {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferences Json     @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────────────────────────────────────

model BlogPost {
  id        Int            @id @default(autoincrement())
  title     String?
  content   String
  mediaUrl  String?
  link      String?
  category  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  likes     BlogPostLike[]
  comments  BlogComment[]

  // ── series support ───────────────────────────────────────────────────────
  // A post can optionally belong to a series (e.g. an event's story
  // submissions). seriesOrder controls its position for "next/previous"
  // navigation. Posts with seriesId = null are standalone, single posts.
  seriesId    Int?
  seriesOrder Int?
  series      BlogSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  isPinned    Boolean  @default(false)

  @@index([createdAt])
  @@index([seriesId])
  @@index([seriesId, seriesOrder])
  @@index([isPinned])
}

// ─────────────────────────────────────────────────────────────────────────────
// BLOG SERIES
//
// Groups related blog posts together (e.g. an ongoing story, or all of the
// submissions for a community event) so they can be browsed as a collection
// and linked with "next/previous" navigation.
// ─────────────────────────────────────────────────────────────────────────────

model BlogSeries {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  description String?
  coverUrl    String?
  category    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  posts       BlogPost[]

  @@index([slug])
}

model BlogPostLike {
  id         Int      @id @default(autoincrement())
  userId     Int
  blogPostId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([userId, blogPostId])
  @@index([blogPostId])
}

model BlogComment {
  id         Int         @id @default(autoincrement())
  blogPostId Int
  authorId   Int?                                                         // <-- nullable
  content    String
  createdAt  DateTime    @default(now())
  post       BlogPost    @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  author     User?       @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull
  replies    BlogReply[]

  @@index([blogPostId])
  @@index([authorId])
}

model BlogReply {
  id        Int         @id @default(autoincrement())
  commentId Int
  authorId  Int?                                                          // <-- nullable
  content   String
  createdAt DateTime    @default(now())
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User?       @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull

  @@index([commentId])
  @@index([authorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// THREADS  (admin-created forum posts; members like, comment, reply)
// ─────────────────────────────────────────────────────────────────────────────

model Thread {
  id        Int      @id @default(autoincrement())
  authorId  Int                                         // always an ADMIN — enforced in service
  title     String
  context   String                                      // the body / "what this post is about"
  mediaUrl  String?                                     // optional image/attachment
  isPinned  Boolean  @default(false)                    // admins can pin important threads
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     ThreadLike[]
  comments  ThreadComment[]

  @@index([authorId])
  @@index([createdAt])
  @@index([isPinned])
}

model ThreadLike {
  id       Int    @id @default(autoincrement())
  userId   Int
  threadId Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@index([threadId])
}

model ThreadComment {
  id        Int      @id @default(autoincrement())
  threadId  Int
  authorId  Int?  // nullable — preserved if user deleted
  mediaUrl   String?
  mediaUrls  Json    @default("[]")                               
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread  Thread              @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author  User?               @relation(fields: [authorId], references: [id], onDelete: SetNull)
  likes   ThreadCommentLike[]
  replies ThreadReply[]

  @@index([threadId])
  @@index([authorId])
}

model ThreadCommentLike {
  id        Int           @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime      @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment ThreadComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model ThreadReply {
  id        Int      @id @default(autoincrement())
  commentId Int
  authorId  Int?    // nullable — preserved if user deleted
  content   String
  mediaUrl   String?
  mediaUrls   Json    @default("[]")                                      
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comment ThreadComment    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author  User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  likes   ThreadReplyLike[]

  @@index([commentId])
  @@index([authorId])
}

model ThreadReplyLike {
  id        Int         @id @default(autoincrement())
  userId    Int
  replyId   Int
  createdAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply ThreadReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@index([replyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WALL POST
// ─────────────────────────────────────────────────────────────────────────────

model WallPost {
  id        Int      @id @default(autoincrement())
  authorId  Int?                                                          // <-- nullable
  profileId Int
  content   String
  createdAt DateTime @default(now())

  author   User?             @relation("WallPostAuthor", fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull
  profile  User              @relation("WallPostProfile", fields: [profileId], references: [id], onDelete: Cascade)
  likes    WallPostLike[]
  comments WallPostComment[]

  @@index([profileId])
  @@index([authorId])
}

model WallPostLike {
  id         Int      @id @default(autoincrement())
  userId     Int
  wallPostId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallPost   WallPost @relation(fields: [wallPostId], references: [id], onDelete: Cascade)

  @@unique([userId, wallPostId])
  @@index([wallPostId])
}

model WallPostComment {
  id         Int      @id @default(autoincrement())
  userId     Int?                                                         // <-- nullable
  wallPostId Int
  content    String
  createdAt  DateTime @default(now())

  user     User?           @relation(fields: [userId], references: [id], onDelete: SetNull) // <-- SetNull
  wallPost WallPost        @relation(fields: [wallPostId], references: [id], onDelete: Cascade)
  replies  WallPostReply[]

  @@index([wallPostId])
  @@index([userId])
}

model WallPostReply {
  id        Int             @id @default(autoincrement())
  userId    Int?                                                          // <-- nullable
  commentId Int
  content   String
  createdAt DateTime        @default(now())

  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull) // <-- SetNull
  comment WallPostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FEEDBACK HUB
// ─────────────────────────────────────────────────────────────────────────────

model FeedbackHubBootstrap {
  id        Int      @id @default(autoincrement())
  posterCount Int    @default(0)

  @@map("feedback_hub_bootstrap")
}

model FeedbackPoint {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  postingBalance Int      @default(5)
  reputation     Int      @default(5)
  usedFreePost   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackSubmission {
  id               Int              @id @default(autoincrement())
  userId           Int
  title            String
  genre            String
  summary          String
  content          String
  critiqueCount    Int              @default(0)
  status           SubmissionStatus @default(QUEUE)
  wordCountTier    WordCountTier
  actualWordCount  Int
  draftStage       DraftStage
  contentWarnings  String[]
  feedbackWanted   String[]
  pointsCost       Int
  wasFreePost      Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  isDraft          Boolean          @default(false)
  unpublishedAt    DateTime?
  writingDraft     WritingDraft?
  

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses         FeedbackResponse[]
  paragraphComments ParagraphComment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([genre])
}

model FeedbackResponse {
  id                  Int                @id @default(autoincrement())
  submissionId        Int
  criticId            Int?                                               // <-- nullable
  generalFeedback     String
  tagResponses        Json?              // optional per-tag feedback, keyed by feedbackWanted tag name
  pointsEarned        Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  critic      User?                  @relation(fields: [criticId], references: [id], onDelete: SetNull) // <-- SetNull
  upvotes     FeedbackResponseUpvote[]
  reports     CritiqueReport[]

  @@index([submissionId])
  @@index([criticId])
}

model FeedbackResponseUpvote {
  id         Int              @id @default(autoincrement())
  userId     Int
  responseId Int
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  response   FeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([userId, responseId])
  @@index([responseId])
}

model CritiqueReport {
  id          Int           @id @default(autoincrement())

  // Who filed the report
  reporterId  Int
  reporter    User          @relation("ReportSubmitter", fields: [reporterId], references: [id], onDelete: Cascade)

  // Which critique (FeedbackResponse) is being reported
  responseId  Int
  response    FeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  // Report content
  reason      String                              // e.g. "Harassment", "Spam", "Unhelpful"
  details     String?                             // optional longer description (≤ 2,000 chars)

  // Lifecycle
  status      ReportStatus  @default(PENDING)
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?

  // Admin who resolved it + optional internal notes
  resolverId  Int?
  resolver    User?         @relation("ReportResolver", fields: [resolverId], references: [id], onDelete: SetNull)
  adminNotes  String?

  // One report per user per critique
  @@unique([reporterId, responseId])

  @@index([responseId])
  @@index([reporterId])
  @@index([status])
  @@index([createdAt])
}

model ParagraphComment {
  id             Int                @id @default(autoincrement())
  submissionId   Int
  authorId       Int?                                                    // <-- nullable
  paragraphIndex Int
  content        String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author      User?                  @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull
  upvotes     ParagraphCommentUpvote[]
  replies     ParagraphCommentReply[]

  @@index([submissionId])
  @@index([submissionId, paragraphIndex])
  @@index([authorId])
}

model ParagraphCommentUpvote {
  id        Int              @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model ParagraphCommentReply {
  id        Int              @id @default(autoincrement())
  commentId Int
  authorId  Int?                                                         // <-- nullable
  content   String
  createdAt DateTime         @default(now())

  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User?            @relation(fields: [authorId], references: [id], onDelete: SetNull) // <-- SetNull

  @@index([commentId])
  @@index([authorId])
}

model WritingDraft {
  id                   Int                 @id @default(autoincrement())
  userId               Int
  title                String?
  content              String              @default("")
  wordCount            Int                 @default(0)

  // If this draft came from unpublishing a submission, link it
  sourceSubmissionId   Int?                @unique

  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSubmission     FeedbackSubmission? @relation(fields: [sourceSubmissionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model DiscoveryStory {
  id              Int      @id @default(autoincrement())
  userId          Int
  title           String
  genre           String
  synopsis        String
  firstChapterTitle String?
  firstChapter    String
  coverUrl        String?
  authorName      String
  recommendedBy   String?
  platform        String
  platformLink    String
  contentWarnings String[] @default([])
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes  DiscoveryLike[]

  @@index([userId])
  @@index([isApproved])
  @@index([createdAt])
  @@index([genre])
}

model DiscoveryLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  storyId   Int
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  story DiscoveryStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([storyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRAFT LEARNING — Emotion Thesaurus daily feature
// ─────────────────────────────────────────────────────────────────────────────

model EmotionEntry {
  id          Int      @id @default(autoincrement())
  emotion     String   // e.g. "Anxiety"
  cues        String[] // physical signal phrases
  scheduledAt DateTime @unique // which day this emotion is shown
  createdAt   DateTime @default(now())

  likes       EmotionLike[]
  comments    EmotionComment[]

  @@index([scheduledAt])
}

model EmotionTemplate {
  id        Int      @id @default(autoincrement())
  emotion   String
  cues      String[]
  sortOrder Int      @unique  // 1, 2, 3 … determines the cycle order

  @@index([sortOrder])
}

model EmotionLike {
  id      Int          @id @default(autoincrement())
  userId  Int
  entryId Int
  createdAt DateTime   @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry   EmotionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([userId, entryId])
  @@index([entryId])
}

model EmotionComment {
  id        Int          @id @default(autoincrement())
  entryId   Int
  authorId  Int?
  content   String
  isPinned  Boolean      @default(false)
  createdAt DateTime     @default(now())

  entry   EmotionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  author  User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  likes   EmotionCommentLike[]

  @@index([entryId])
  @@index([authorId])
}

model EmotionCommentLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime       @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment EmotionComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SPONSOR
  FOUNDING_WRITER
}

enum SnippetSource {
  POST_SPRINT
  STANDALONE
  DAYS_CHALLENGE
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum SprintType {
  WRITING
  READING
}

enum DraftStage {
  ROUGH      // be gentle
  POLISHING  // be honest
  FINAL_EDIT // be ruthless
}

enum SubmissionStatus {
  QUEUE      // waiting for first critique
  SPOTLIGHT  // received ≥1 critique, actively featured
  ARCHIVE    // received ≥3 critiques, closed for new feedback
}

enum WordCountTier {
  TIER_1000  // ≤1,000 words — costs/earns 1 pt
  TIER_2000  // ≤2,000 words — costs/earns 2 pts
  TIER_3000  // ≤3,000 words — costs/earns 3 pts
  TIER_4000  // ≤4,000 words — costs/earns 4 pts
  TIER_5000  // ≤5,000 words — costs/earns 5 pts
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum GoalType {
  WORDS
  CHAPTERS
  SCENES
  DURATION   // stored in minutes
}
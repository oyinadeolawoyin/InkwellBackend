generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String    @unique
  password         String
  avatar           String?
  bio              String?
  role             Role      @default(USER)
  createdAt        DateTime  @default(now())
  timezone         String    @default("UTC")
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  groupSprints       GroupSprint[]
  sprints            Sprint[]
  notification       Notification[]
  projects           Project[]
  quoteLikes         QuoteLike[]
  blogPostLikes      BlogPostLike[]
  blogComments       BlogComment[]
  blogReplies        BlogReply[]
  writingSnippets    WritingSnippet[]
  snippetLikes       SnippetLike[]
  snippetComments    SnippetComment[]
  snippetReplies     SnippetReply[]
  wallPostsAuthored   WallPost[]        @relation("WallPostAuthor")
  wallPostsReceived   WallPost[]        @relation("WallPostProfile")
  wallPostLikes       WallPostLike[]
  wallPostComments    WallPostComment[]
  wallPostReplies     WallPostReply[]
}

model Project {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  link        String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── GROUP SPRINT ─────────────────────────────────────────────

model GroupSprint {
  id             Int       @id @default(autoincrement())
  userId         Int
  duration       Int
  totalWordsWritten Int @default(0)
  soundscape     String?   // e.g. "rain", "birds", "cafe"
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  isActive       Boolean   @default(true)

  sprints        Sprint[]
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([startedAt])
}

// Stripped down — only tracks who is inside a group sprint
model Sprint {
  id            Int          @id @default(autoincrement())
  userId        Int
  groupSprintId Int?
  checkin       String?
  startWords    Int          @default(0)
  wordsWritten  Int          @default(0)
  deletedWords  Int          @default(0)
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  isActive      Boolean      @default(true)

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupSprint   GroupSprint? @relation(fields: [groupSprintId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([groupSprintId])
  @@index([isActive])
}

// ─── WEEKLY SESSION SCHEDULE ──────────────────────────────────

model SessionSchedule {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  dayOfWeek   Int      // 0=Sun, 1=Mon ... 6=Sat
  time        String   // "HH:mm" UTC
  timezone    String   @default("UTC")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([dayOfWeek])
  @@index([isActive])
}

// ─── WRITING SNIPPET ──────────────────────────────────────────

model WritingSnippet {
  id         Int           @id @default(autoincrement())
  userId     Int
  content    String
  proudOf    String?
  struggle   String?
  sourceType SnippetSource @default(POST_SPRINT)
  tags       String? // e.g. "pacing,dialogue,worldbuilding" — comma separated
  createdAt  DateTime      @default(now())
  
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes      SnippetLike[]
  comments   SnippetComment[]

  @@index([userId])
  @@index([createdAt])
}

model SnippetLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  snippetId Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet   WritingSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])
  @@index([snippetId])
}

model SnippetComment {
  id        Int            @id @default(autoincrement())
  userId    Int
  snippetId Int
  content   String
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet   WritingSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  replies   SnippetReply[]

  @@index([snippetId])
  @@index([userId])
}

model SnippetReply {
  id        Int            @id @default(autoincrement())
  userId    Int
  commentId Int
  content   String
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
}

// ─── EXISTING MODELS (KEPT) ───────────────────────────────────

model Quote {
  id        Int         @id @default(autoincrement())
  title     String?
  content   String
  createdAt DateTime    @default(now())
  likes     QuoteLike[]
}

model QuoteLike {
  id      Int   @id @default(autoincrement())
  userId  Int
  quoteId Int
  user    User  @relation(fields: [userId], references: [id])
  quote   Quote @relation(fields: [quoteId], references: [id])

  @@unique([userId, quoteId])
}

model Subscription {
  id           Int      @id @default(autoincrement())
  userId       Int
  subscription Json
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  username  String
  userId    Int
  message   String?
  link      String?
  read      Boolean? @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model BlogPost {
  id        Int            @id @default(autoincrement())
  title     String?
  content   String
  mediaUrl  String?
  link      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  likes     BlogPostLike[]
  comments  BlogComment[]

  @@index([createdAt])
}

model BlogPostLike {
  id         Int      @id @default(autoincrement())
  userId     Int
  blogPostId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([userId, blogPostId])
  @@index([blogPostId])
}

model BlogComment {
  id         Int         @id @default(autoincrement())
  blogPostId Int
  authorId   Int
  content    String
  createdAt  DateTime    @default(now())
  post       BlogPost    @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  author     User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies    BlogReply[]

  @@index([blogPostId])
  @@index([authorId])
}

model BlogReply {
  id        Int         @id @default(autoincrement())
  commentId Int
  authorId  Int
  content   String
  createdAt DateTime    @default(now())
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([authorId])
}

model WallPost {
  id          Int           @id @default(autoincrement())
  authorId    Int           // who wrote the post
  profileId   Int           // whose wall it's on
  content     String
  createdAt   DateTime      @default(now())

  author      User          @relation("WallPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  profile     User          @relation("WallPostProfile", fields: [profileId], references: [id], onDelete: Cascade)
  likes       WallPostLike[]
  comments    WallPostComment[]

  @@index([profileId])
  @@index([authorId])
}

model WallPostLike {
  id         Int      @id @default(autoincrement())
  userId     Int
  wallPostId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallPost   WallPost @relation(fields: [wallPostId], references: [id], onDelete: Cascade)

  @@unique([userId, wallPostId])
  @@index([wallPostId])
}

model WallPostComment {
  id         Int      @id @default(autoincrement())
  userId     Int
  wallPostId Int
  content    String
  createdAt  DateTime @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallPost   WallPost        @relation(fields: [wallPostId], references: [id], onDelete: Cascade)
  replies    WallPostReply[]

  @@index([wallPostId])
  @@index([userId])
}

model WallPostReply {
  id        Int             @id @default(autoincrement())
  userId    Int
  commentId Int
  content   String
  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   WallPostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
}

// ─── ENUMS ────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SPONSOR
  FOUNDING_WRITER
}

enum SnippetSource {
  POST_SPRINT
  STANDALONE
}
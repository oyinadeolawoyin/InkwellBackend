generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String?   @unique
  password         String?
  discordId        String?   @unique
  createdVia       String    @default("site")
  avatar           String?
  bio              String?
  dateOfBirth      DateTime?
  role             Role      @default(USER)
  createdAt        DateTime  @default(now())
  timezone         String    @default("UTC")
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // ── existing relations ──────────────────────────────────────────────────
  groupSprints        GroupSprint[]
  sprints             Sprint[]
  notification        Notification[]
  projects            Project[]
  todolists           Todolist[]
  notes               Note[]
  quoteLikes          QuoteLike[]
  blogPostLikes       BlogPostLike[]
  blogComments        BlogComment[]
  blogReplies         BlogReply[]
  writingSnippets     WritingSnippet[]
  snippetLikes        SnippetLike[]
  snippetComments     SnippetComment[]
  snippetReplies      SnippetReply[]
  snippetCommentLikes SnippetCommentLike[]
  snippetReplyLikes   SnippetReplyLike[]
  wallPostsAuthored   WallPost[]           @relation("WallPostAuthor")
  wallPostsReceived   WallPost[]           @relation("WallPostProfile")
  wallPostLikes       WallPostLike[]
  wallPostComments    WallPostComment[]
  wallPostReplies     WallPostReply[]
  soundscapes         Soundscape[]

  // ── feedback hub relations ──────────────────────────────────────────────
  feedbackPoints              FeedbackPoint?
  feedbackSubmissions         FeedbackSubmission[]
  feedbackResponses           FeedbackResponse[]
  paragraphComments           ParagraphComment[]
  paragraphCommentReplies     ParagraphCommentReply[]
  paragraphCommentUpvotes     ParagraphCommentUpvote[]
  feedbackResponseUpvotes     FeedbackResponseUpvote[]

  discoveryStories            DiscoveryStory[]
  discoveryLikes              DiscoveryLike[]
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM EVENTS  (carousel notices + days challenges)
// ─────────────────────────────────────────────────────────────────────────────


model PlatformEvent {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  bannerUrl   String?                     // optional hero image for the carousel card
  type        EventType
  // For DAYS_CHALLENGE: how many consecutive days writers must maintain
  daysTarget  Int?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Projects currently enrolled in this event (public + streak still alive)
  entries     ProjectEventEntry[]

  @@index([isActive])
  @@index([type])
  @@index([startDate, endDate])
}

// Join table: a public project opts into a DAYS_CHALLENGE event.
// Row is soft-deleted (disqualified = true) when the streak resets,
// which also triggers the project visibility flip to PRIVATE in the service.
model ProjectEventEntry {
  id              Int           @id @default(autoincrement())
  projectId       Int
  eventId         Int
  enrolledAt      DateTime      @default(now())
  disqualified    Boolean       @default(false)
  disqualifiedAt  DateTime?

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  event           PlatformEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // one entry per project per event
  @@unique([projectId, eventId])
  @@index([eventId])
  @@index([projectId])
  @@index([disqualified])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id               Int       @id @default(autoincrement())
  userId           Int
  title            String
  description      String?
  link             String?
  genre            String?
  visibility       Visibility    @default(PRIVATE)

  // ── Writing phase ──────────────────────────────────────────────────────
  phase            WritingPhase  @default(DRAFTING)

  // ── Word / chapter / scene targets ────────────────────────────────────
  targetWordCount  Int?
  currentWordCount Int        @default(0)
  targetChapters   Int?
  currentChapters  Int        @default(0)
  targetScenes     Int?
  currentScenes    Int        @default(0)

  // ── Session goal ───────────────────────────────────────────────────────
  sessionGoalType     SessionGoalType?
  sessionGoalCount    Int?
  currentSessionCount Int    @default(0)
  lastSessionReset    DateTime?

  // ── Consecutive-days streak tracker ───────────────────────────────────
  // How many days in a row the writer wants to write (set by the user).

  consecutiveDaysTarget Int?

  // Current streak count. Resets to 0 if a day is missed.

  currentStreak         Int       @default(0)
  
  // UTC calendar date of the last day log (date only, stored as DateTime).
  // Used to detect whether today has been logged and whether a day was skipped.
  lastLogDate           DateTime?

  // ── Deadline / schedule ────────────────────────────────────────────────
  deadline         DateTime?
  daysPerWeek      Int           @default(5)
  status           ProjectStatus @default(IN_PROGRESS)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordLogs         ProjectWordLog[]
  progressLogs     ProjectProgressLog[]
  sessionLogs      ProjectSessionLog[]
  // One log entry per calendar day for the streak system
  dayLogs          ProjectDayLog[]
  todolists        Todolist[]
  notes            Note[]
  sprints          Sprint[]
  // Events this project is enrolled in
  eventEntries     ProjectEventEntry[]

  @@index([userId])
  @@index([visibility])
}

// ─── Day Log (streak system) ──────────────────────────────────────────────────
// One row per calendar day per project. The writer must log at least one of:
//   wordsLogged, chaptersLogged, scenesLogged, minutesLogged
// to "count" the day towards their consecutive streak.
model ProjectDayLog {
  id             Int      @id @default(autoincrement())
  projectId      Int
  userId         Int
  // Calendar date this log counts for (stored as midnight UTC, e.g. 2025-04-27T00:00:00Z)
  logDate        DateTime
  // At least one of the four fields below must be > 0
  wordsLogged    Int      @default(0)
  chaptersLogged Int      @default(0)
  scenesLogged   Int      @default(0)
  minutesLogged  Int      @default(0)
  // Snapshot of the streak value after this log was saved
  streakAtLog    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Only one day-log per calendar day per project
  @@unique([projectId, logDate])
  @@index([projectId])
  @@index([userId])
  @@index([logDate])
}

model ProjectWordLog {
  id          Int      @id @default(autoincrement())
  projectId   Int
  userId      Int
  wordsAdded  Int
  loggedAt    DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([loggedAt])
}

model ProjectProgressLog {
  id             Int      @id @default(autoincrement())
  projectId      Int
  userId         Int
  chaptersAdded  Int      @default(0)
  scenesAdded    Int      @default(0)
  loggedAt       DateTime @default(now())

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([loggedAt])
}

model ProjectSessionLog {
  id         Int      @id @default(autoincrement())
  projectId  Int
  userId     Int
  loggedAt   DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([loggedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// TODOLIST & NOTES
// ─────────────────────────────────────────────────────────────────────────────

model Todolist {
  id           Int      @id @default(autoincrement())
  task         String
  index        Int
  markComplete Boolean  @default(false)
  projectId    Int
  userId       Int
  createdAt    DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([index])
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String?
  note      String
  projectId Int
  userId    Int
  createdAt DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// GROUP SPRINT & SPRINT
// ─────────────────────────────────────────────────────────────────────────────

model GroupSprint {
  id                Int        @id @default(autoincrement())
  userId            Int
  duration          Int
  totalWordsWritten Int        @default(0)
  liveKitRoomName   String?
  visibility        Visibility @default(PUBLIC)
  sprintType        SprintType @default(WRITING)
  startedAt         DateTime   @default(now())
  completedAt       DateTime?
  isActive          Boolean    @default(true)

  sprints           Sprint[]
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([startedAt])
  @@index([visibility])
}

model Sprint {
  id            Int          @id @default(autoincrement())
  userId        Int
  groupSprintId Int?
  soundscapeId  Int?
  projectId     Int?
  checkin       String?
  startWords    Int          @default(0)
  wordsWritten  Int          @default(0)
  deletedWords  Int          @default(0)
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  isActive      Boolean      @default(true)

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupSprint   GroupSprint? @relation(fields: [groupSprintId], references: [id], onDelete: SetNull)
  soundscape    Soundscape?  @relation(fields: [soundscapeId], references: [id], onDelete: SetNull)
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([groupSprintId])
  @@index([isActive])
  @@index([soundscapeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SOUNDSCAPE
// ─────────────────────────────────────────────────────────────────────────────

model Soundscape {
  id            Int       @id @default(autoincrement())
  name          String
  creatorName   String?
  fileUrl       String
  contributedBy Int
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  contributor   User      @relation(fields: [contributedBy], references: [id], onDelete: Cascade)
  sprints       Sprint[]

  @@index([contributedBy])
  @@index([isApproved])
}

// ─────────────────────────────────────────────────────────────────────────────
// WEEKLY SCHEDULE
// ─────────────────────────────────────────────────────────────────────────────

model WeeklySchedule {
  id          Int      @id @default(autoincrement())
  weekStart   DateTime @unique
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions ScheduledSession[]

  @@index([weekStart])
  @@index([isActive])
}

model ScheduledSession {
  id          Int      @id @default(autoincrement())
  scheduleId  Int
  dayOfWeek   Int
  time        String
  label       String?
  isDone      Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  schedule WeeklySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([dayOfWeek])
  @@index([isDone])
}

// ─────────────────────────────────────────────────────────────────────────────
// WRITING SNIPPET
// ─────────────────────────────────────────────────────────────────────────────

model WritingSnippet {
  id         Int           @id @default(autoincrement())
  userId     Int
  context    String?
  mediaUrl   String?
  sourceType SnippetSource @default(POST_SPRINT)
  tags       String?
  createdAt  DateTime      @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes      SnippetLike[]
  comments   SnippetComment[]

  @@index([userId])
  @@index([createdAt])
}

model SnippetLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  snippetId Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet   WritingSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])
  @@index([snippetId])
}

model SnippetComment {
  id        Int            @id @default(autoincrement())
  userId    Int
  snippetId Int
  content   String
  createdAt DateTime       @default(now())

  likes     SnippetCommentLike[]
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet   WritingSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  replies   SnippetReply[]

  @@index([snippetId])
  @@index([userId])
}

model SnippetReply {
  id        Int            @id @default(autoincrement())
  userId    Int
  commentId Int
  content   String
  createdAt DateTime       @default(now())

  likes     SnippetReplyLike[]
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
}

model SnippetCommentLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  commentId Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   SnippetComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model SnippetReplyLike {
  id      Int          @id @default(autoincrement())
  userId  Int
  replyId Int
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply   SnippetReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@index([replyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// QUOTES, SUBSCRIPTIONS, NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Quote {
  id        Int         @id @default(autoincrement())
  title     String?
  content   String
  createdAt DateTime    @default(now())
  likes     QuoteLike[]
}

model QuoteLike {
  id      Int   @id @default(autoincrement())
  userId  Int
  quoteId Int
  user    User  @relation(fields: [userId], references: [id])
  quote   Quote @relation(fields: [quoteId], references: [id])

  @@unique([userId, quoteId])
}

model Subscription {
  id           Int      @id @default(autoincrement())
  userId       Int
  subscription Json
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  username  String
  userId    Int
  message   String?
  link      String?
  read      Boolean? @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

// ─────────────────────────────────────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────────────────────────────────────

model BlogPost {
  id        Int            @id @default(autoincrement())
  title     String?
  content   String
  mediaUrl  String?
  link      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  likes     BlogPostLike[]
  comments  BlogComment[]

  @@index([createdAt])
}

model BlogPostLike {
  id         Int      @id @default(autoincrement())
  userId     Int
  blogPostId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([userId, blogPostId])
  @@index([blogPostId])
}

model BlogComment {
  id         Int         @id @default(autoincrement())
  blogPostId Int
  authorId   Int
  content    String
  createdAt  DateTime    @default(now())
  post       BlogPost    @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  author     User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies    BlogReply[]

  @@index([blogPostId])
  @@index([authorId])
}

model BlogReply {
  id        Int         @id @default(autoincrement())
  commentId Int
  authorId  Int
  content   String
  createdAt DateTime    @default(now())
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([authorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// WALL POST
// ─────────────────────────────────────────────────────────────────────────────

model WallPost {
  id        Int      @id @default(autoincrement())
  authorId  Int
  profileId Int
  content   String
  createdAt DateTime @default(now())

  author   User              @relation("WallPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  profile  User              @relation("WallPostProfile", fields: [profileId], references: [id], onDelete: Cascade)
  likes    WallPostLike[]
  comments WallPostComment[]

  @@index([profileId])
  @@index([authorId])
}

model WallPostLike {
  id         Int      @id @default(autoincrement())
  userId     Int
  wallPostId Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallPost   WallPost @relation(fields: [wallPostId], references: [id], onDelete: Cascade)

  @@unique([userId, wallPostId])
  @@index([wallPostId])
}

model WallPostComment {
  id         Int      @id @default(autoincrement())
  userId     Int
  wallPostId Int
  content    String
  createdAt  DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallPost WallPost        @relation(fields: [wallPostId], references: [id], onDelete: Cascade)
  replies  WallPostReply[]

  @@index([wallPostId])
  @@index([userId])
}

model WallPostReply {
  id        Int             @id @default(autoincrement())
  userId    Int
  commentId Int
  content   String
  createdAt DateTime        @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment WallPostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FEEDBACK HUB
// ─────────────────────────────────────────────────────────────────────────────

// Tracks how many unique users have ever posted a submission.
// Used to grant the first 5 posters a free pass (no points required).
model FeedbackHubBootstrap {
  id        Int      @id @default(autoincrement())
  // total distinct users who have ever submitted — only increments, never decrements
  posterCount Int    @default(0)

  // Singleton row — always id = 1
  @@map("feedback_hub_bootstrap")
}

// ─── Point wallet ────────────────────────────────────────────────────────────

model FeedbackPoint {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  postingBalance Int      @default(5)   // spendable — goes up and down
  reputation     Int      @default(5)   // lifetime total — only ever goes up
  // tracks whether this user has already used their bootstrap free post
  usedFreePost   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Submission (chapter posted for feedback) ─────────────────────────────────

model FeedbackSubmission {
  id               Int             @id @default(autoincrement())
  userId           Int
  title            String
  genre            String
  summary          String          // 25–60 words enforced in service
  content          String          // full chapter text
  critiqueCount    Int      @default(0) // Tracks the number of critiques
  isOutdated       Boolean  @default(false) // Marks if the post is no longer in Spotlight
  wordCountTier    WordCountTier
  actualWordCount  Int             // counted server-side on submit
  draftStage       DraftStage
  contentWarnings  String[]
  feedbackWanted   String[]        // free-text tags from writer
  pointsCost       Int             // 0 if bootstrap free post, else 10/20/30/40
  wasFreePost      Boolean         @default(false)
  isOpen           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses         FeedbackResponse[]
  paragraphComments ParagraphComment[]

  @@index([userId])
  @@index([isOpen])
  @@index([createdAt])
  @@index([genre])
}

// ─── Full critique (ratings + general feedback) ───────────────────────────────

model FeedbackResponse {
  id                  Int                @id @default(autoincrement())
  submissionId        Int
  criticId            Int
  overallRating       Int                // 1–5
  clarityRating       Int                // 1–5
  pacingRating        Int                // 1–5
  believabilityRating Int                // 1–5
  generalFeedback     String             // ≥100 words enforced in service
  pointsEarned        Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  critic      User                   @relation(fields: [criticId], references: [id], onDelete: Cascade)
  upvotes     FeedbackResponseUpvote[]

  // One full response per critic per submission
  @@unique([submissionId, criticId])
  @@index([submissionId])
  @@index([criticId])
}

// Upvote on a full critique — submission author only, gives critic +3 pts
model FeedbackResponseUpvote {
  id         Int              @id @default(autoincrement())
  userId     Int
  responseId Int
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  response   FeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([userId, responseId])
  @@index([responseId])
}

// ─── Paragraph comment ────────────────────────────────────────────────────────

model ParagraphComment {
  id             Int                @id @default(autoincrement())
  submissionId   Int
  authorId       Int
  paragraphIndex Int                // 0-based paragraph position
  content        String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  submission  FeedbackSubmission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author      User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  upvotes     ParagraphCommentUpvote[]
  replies     ParagraphCommentReply[]

  @@index([submissionId])
  @@index([submissionId, paragraphIndex])
  @@index([authorId])
}

// Upvote on a paragraph comment — any user except comment author, gives author +3 pts
model ParagraphCommentUpvote {
  id        Int              @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

// One-level reply on a paragraph comment (no nested threading)
model ParagraphCommentReply {
  id        Int              @id @default(autoincrement())
  commentId Int
  authorId  Int
  content   String
  createdAt DateTime         @default(now())

  comment   ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([authorId])
}

model DiscoveryStory {
  id              Int      @id @default(autoincrement())
  userId          Int                         // the person who submitted
  title           String
  genre           String
  synopsis        String
  firstChapterTitle String?                   // title of the opening chapter
  firstChapter    String                      // full chapter text
  coverUrl        String?                     // uploaded cover image
  authorName      String                      // real author name (may differ from submitter)
  recommendedBy   String?                     // if submitted by someone other than the author
  platform        String                      // e.g. "Wattpad", "Kindle", "Royal Road"
  platformLink    String                      // URL to the story on that platform
  contentWarnings String[] @default([])       // e.g. ["Violence", "Strong language"]
  isApproved      Boolean  @default(false)    // admin approval gate
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes  DiscoveryLike[]

  @@index([userId])
  @@index([isApproved])
  @@index([createdAt])
  @@index([genre])
}

model DiscoveryLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  storyId   Int
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  story DiscoveryStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([storyId])
}

